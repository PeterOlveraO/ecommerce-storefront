---
import ClientRouter from 'astro/components/ClientRouter.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

// Props configurables por cada página
interface Props {
  title?: string;
  description?: string;
  navbarSolid?: boolean;
  lang?: string;
}

const {
  title = 'Vapezone',
  description = 'Tu tienda de vapes y accesorios.',
  navbarSolid = false,
  lang = 'es',
} = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/x-icon" href="/favicon.png" />
    <link
      href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;700&family=Inter:wght@300;400;600;700&display=swap"
      rel="stylesheet"
    />
    <!-- Activa el modo SPA: intercepta la navegación y anima las transiciones entre páginas -->
    <ClientRouter />
  </head>
  <body>
    <Navbar solid={navbarSolid} />
    <slot />
    <Footer />
  </body>
</html>
