---
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Iniciar Sesión - Vapezone</title>
        <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />
        <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;700&family=Inter:wght@300;400&display=swap" rel="stylesheet" />
    </head>
    <body>
        <Navbar solid={true} />
        <div class="auth-container">
            <div class="auth-card reveal-item">
                <h1>INICIAR SESIÓN</h1>
                <p>Accede a tu cuenta para continuar tus compras.</p>
                <form id="login-form" class="auth-form">
                    <div class="form-group">
                        <label for="identifier">Correo Electrónico o Teléfono</label>
                        <input type="text" id="identifier" name="identifier" required placeholder="tu@email.com o teléfono" />
                    </div>
                    <div class="form-group">
                        <label for="password">Contraseña</label>
                        <input type="password" id="password" name="password" required placeholder="••••••••" />
                    </div>
                    <button type="submit" id="submit-btn" class="submit-btn">INGRESAR</button>
                    <div id="auth-message" class="auth-message"></div>
                </form>
                <p class="switch-auth">¿No tienes cuenta? <a href="/register">Regístrate aquí</a></p>
            </div>
        </div>
        <Footer />
        <script>
            document.addEventListener('DOMContentLoaded', () => {
                const card = document.querySelector('.auth-card');
                setTimeout(() => card?.classList.add('visible'), 100);

                const form = document.getElementById('login-form');
                const msg = document.getElementById('auth-message');
                const btn = document.getElementById('submit-btn');
                
                const API_BASE_URL = "http://localhost:3000";

                form?.addEventListener('submit', async (e) => {
                    e.preventDefault();
                    if(btn) (btn as HTMLButtonElement).disabled = true;
                    if(msg) { msg.textContent = 'Verificando credenciales...'; msg.className = 'auth-message loading'; }

                    const identifier = (document.getElementById('identifier') as HTMLInputElement).value;
                    const password = (document.getElementById('password') as HTMLInputElement).value;

                    try {
                        const res = await fetch(`${API_BASE_URL}/auth/login`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ identifier, password })
                        });
                        const data = await res.json();

                        if (res.ok && (data.success || data.data)) {
                            if(msg) { msg.textContent = 'Acceso concedido. Redirigiendo...'; msg.className = 'auth-message success'; }
                            // El backend retorna data.data.access_token según la guía
                            const token = data.data?.access_token || data.access_token || data.token;
                            localStorage.setItem('angel_token', token);
                            
                            // Guardamos los datos del usuario extraídos de la respuesta del login
                            const user = data.data?.user || { email: identifier, role: 'customer' };
                            localStorage.setItem('angel_user', JSON.stringify(user));

                            setTimeout(() => {
                                const urlParams = new URLSearchParams(window.location.search);
                                const redirect = urlParams.get('redirect');
                                if (redirect === 'cart') {
                                    window.location.href = '/?openCart=true';
                                } else {
                                    window.location.href = '/';
                                }
                            }, 1000);
                        } else {
                            throw new Error(data.message || 'Credenciales incorrectas');
                        }
                    } catch (error: any) {
                        console.error("API Error:", error);
                        if(msg) { msg.textContent = error.message || 'Error al conectar con el servidor.'; msg.className = 'auth-message error'; }
                        if(btn) (btn as HTMLButtonElement).disabled = false;
                    }
                });
            });
        </script>
    </body>
</html>

<style is:global>
    body {
        background-color: #000;
        color: #fff;
        font-family: "Inter", sans-serif;
        margin: 0;
    }
    
    .auth-container {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 6rem 1rem 2rem 1rem;
        background: linear-gradient(to bottom, #111, #000);
    }

    .auth-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.05);
        padding: 3rem 2rem;
        border-radius: 12px;
        width: 100%;
        max-width: 450px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.5s ease, transform 0.5s ease;
    }

    .auth-card.visible {
        opacity: 1;
        transform: translateY(0);
    }

    .auth-card h1 {
        font-family: "Oswald", sans-serif;
        font-size: 2.5rem;
        text-align: center;
        margin-bottom: 0.5rem;
        letter-spacing: 2px;
        color: #fff;
    }

    .auth-card > p {
        text-align: center;
        color: rgba(255,255,255,0.6);
        margin-bottom: 2rem;
        font-size: 0.95rem;
    }

    .form-group {
        margin-bottom: 1.5rem;
    }

    .form-group label {
        display: block;
        margin-bottom: 0.5rem;
        font-size: 0.9rem;
        color: rgba(255,255,255,0.8);
    }

    .form-group input {
        width: 100%;
        padding: 0.8rem 1rem;
        background: rgba(0,0,0,0.5);
        border: 1px solid rgba(255,255,255,0.2);
        color: #fff;
        border-radius: 4px;
        font-family: "Inter", sans-serif;
        transition: border-color 0.3s;
        box-sizing: border-box;
    }

    .form-group input:focus {
        outline: none;
        border-color: #fff;
    }

    .submit-btn {
        width: 100%;
        padding: 1rem;
        background: #fff;
        color: #000;
        border: none;
        font-family: "Oswald", sans-serif;
        font-size: 1.1rem;
        font-weight: 700;
        cursor: pointer;
        transition: background 0.3s, transform 0.3s;
        border-radius: 4px;
        margin-top: 1rem;
    }

    .submit-btn:hover {
        background: #f0f0f0;
        transform: translateY(-2px);
    }

    .submit-btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
        transform: none;
    }

    .auth-message {
        margin-top: 1rem;
        text-align: center;
        font-size: 0.9rem;
        min-height: 20px;
    }

    .auth-message.error {
        color: #f44336;
    }

    .auth-message.success {
        color: #4caf50;
    }

    .auth-message.loading {
        color: rgba(255,255,255,0.6);
    }

    .switch-auth {
        text-align: center;
        margin-top: 2rem;
        font-size: 0.9rem;
        color: rgba(255,255,255,0.6);
    }

    .switch-auth a {
        color: #fff;
        text-decoration: underline;
    }
</style>
