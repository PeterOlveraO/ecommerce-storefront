---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroCarousel from "../components/HeroCarousel.astro";
import ProductCard from "../components/ProductCard.astro";

const API_BASE_URL = import.meta.env.PUBLIC_API_URL || "http://localhost:3000";

let headerProducts: any[] = [];
let categories: any[] = [];
let allCategories: any[] = [];
let gridProducts: any[] = [];

try {
    // Fetch Header Images
    const headerRes = await fetch(`${API_BASE_URL}/header-images`);
    if (headerRes.ok) {
        const result = await headerRes.json();
        if (result.success && result.data) {
            const defaultColors = ["#ff4d88", "#4d88ff", "#4dff88", "#b34dff"];
            const activeHeaders = result.data
                .filter((img: any) => img.is_active)
                .sort((a: any, b: any) => a.display_order - b.display_order);

            headerProducts = await Promise.all(
                activeHeaders.map(async (img: any, index: number) => {
                    let productData: any = null;
                    let isProductLink = false;
                    let linkUrl = img.link_url || "";

                    if (linkUrl.includes("product/")) {
                        isProductLink = true;
                        const parts = linkUrl.split("product/");
                        if (parts.length > 1) {
                            const productId = parts[1].replace(/^\//, "");
                            try {
                                const prodRes = await fetch(
                                    `${API_BASE_URL}/products/${productId}`,
                                );
                                if (prodRes.ok) {
                                    const prodJson = await prodRes.json();
                                    if (prodJson.success && prodJson.data) {
                                        productData = prodJson.data;
                                    }
                                }
                            } catch (e) {
                                console.error(
                                    "Error fetching product for banner:",
                                    e,
                                );
                            }
                        }
                    }

                    return {
                        id: img.id,
                        name: productData
                            ? productData.name
                            : img.name || "Promo",
                        tagline: productData
                            ? productData.brand
                            : isProductLink
                              ? "Destacado"
                              : "Novedad",
                        price: productData
                            ? productData.sale_price || productData.price
                            : "",
                        original_price: productData
                            ? productData.sale_price
                                ? productData.price
                                : ""
                            : "",
                        description: productData ? productData.description : "",
                        image: img.image_url,
                        color: defaultColors[index % defaultColors.length],
                        link: linkUrl.startsWith("/") ? linkUrl : `/${linkUrl}`,
                        is_product: isProductLink,
                    };
                }),
            );
        }
    }

    // Fetch Categories and their preview products
    const catRes = await fetch(`${API_BASE_URL}/categories`);
    if (catRes.ok) {
        const catResult = await catRes.json();
        if (catResult.success && catResult.data) {
            const activeCats = catResult.data
                .filter((cat: any) => cat.is_active && cat.display_order >= 1)
                .sort((a: any, b: any) => a.display_order - b.display_order);

            allCategories = activeCats;

            for (let cat of activeCats) {
                const catProdRes = await fetch(
                    `${API_BASE_URL}/products?category_id=${cat.id}&limit=50`,
                );
                if (catProdRes.ok) {
                    const cpResult = await catProdRes.json();
                    if (cpResult.success && cpResult.data) {
                        cat.products = cpResult.data
                            .filter(
                                (p: any) =>
                                    p.is_active &&
                                    p.featured != 1 &&
                                    p.featured !== true &&
                                    p.featured !== "1",
                            )
                            .sort(
                                (a: any, b: any) =>
                                    a.display_order - b.display_order,
                            )
                            .slice(0, 4);
                    } else {
                        cat.products = [];
                    }
                } else {
                    cat.products = [];
                }
            }
            categories = activeCats
                .filter((cat: any) => cat.products && cat.products.length > 0)
                .slice(0, 5);
        }
    }
} catch (error) {
    console.error("Error fetching data:", error);
}
---
<BaseLayout title="Vapezone">
        <HeroCarousel headerProducts={headerProducts} />

        <div class="shop-layout container" style="margin-top: 4rem;">
            <aside class="shop-sidebar">
                <div class="filter-group">
                    <h3 class="filter-title">Buscar Producto</h3>
                    <div class="search-wrapper" style="position: relative;">
                        <input
                            type="text"
                            id="product-search"
                            placeholder="Escribe para buscar..."
                            autocomplete="off"
                        />
                        <div id="search-dropdown" class="search-dropdown"></div>
                    </div>
                </div>

                <div class="filter-group">
                    <h3 class="filter-title">Categorías</h3>
                    <ul class="category-list">
                        <li>
                            <a href="/" class="active">Inicio</a>
                        </li>
                        {
                            allCategories.map((cat: any) => (
                                <li>
                                    <a href={`/category/${cat.id}`}>
                                        {cat.name}
                                    </a>
                                </li>
                            ))
                        }
                    </ul>
                </div>
            </aside>

            <div class="shop-content">
                {
                    categories.map((category) => (
                        <section class="store-section reveal-on-scroll">
                            <div class="category-header reveal-item">
                                <h2 class="section-title">{category.name}</h2>
                                <a
                                    href={`/category/${category.id}`}
                                    class="category-link"
                                >
                                    Ver todo{" "}
                                    <svg
                                        width="16"
                                        height="16"
                                        viewBox="0 0 24 24"
                                        fill="none"
                                        stroke="currentColor"
                                        stroke-width="2"
                                    >
                                        <path d="M5 12h14M12 5l7 7-7 7" />
                                    </svg>
                                </a>
                            </div>

                            <div class="products-grid">
                                {category.products.map(
                                    (product: any, index: number) => (
                                        <ProductCard
                                            product={product}
                                            index={index}
                                        />
                                    ),
                                )}
                            </div>
                        </section>
                    ))
                }
            </div>
        </div>

        <!-- Features / Benefits Section -->
        <section class="store-features reveal-on-scroll">
            <div class="container">
                <div class="features-grid">
                    <div class="feature-card reveal-item">
                        <div class="feature-icon">🇲🇽</div>
                        <h3>Envíos a todo México</h3>
                        <p>
                            Recibe tus productos de forma rápida y confiable en
                            cualquier rincón del país.
                        </p>
                    </div>
                    <div
                        class="feature-card reveal-item"
                        style="transition-delay: 100ms"
                    >
                        <div class="feature-icon">🔒</div>
                        <h3>Compra Segura</h3>
                        <p>
                            Tus transacciones y datos están protegidos en todo
                            momento para tu total tranquilidad.
                        </p>
                    </div>
                    <div
                        class="feature-card reveal-item"
                        style="transition-delay: 200ms"
                    >
                        <div class="feature-icon">💬</div>
                        <h3>Soporte vía Discord</h3>
                        <p>
                            Atención rápida y personalizada. Únete a nuestra
                            comunidad para aclarar cualquier duda.
                        </p>
                    </div>
                    <div
                        class="feature-card reveal-item"
                        style="transition-delay: 300ms"
                    >
                        <div class="feature-icon">⚠️</div>
                        <h3>Política de Ventas</h3>
                        <p>
                            Garantizamos productos nuevos y sellados. Por
                            motivos de higiene y seguridad, no manejamos
                            devoluciones.
                        </p>
                    </div>
                </div>
            </div>
        </section>



        <script>
            document.addEventListener("astro:page-load", () => {
                const observerOptions = {
                    root: null,
                    rootMargin: "0px",
                    threshold: 0.15,
                };

                const observer = new IntersectionObserver(
                    (entries, observer) => {
                        entries.forEach((entry) => {
                            if (entry.isIntersecting) {
                                entry.target.classList.add("is-visible");
                                observer.unobserve(entry.target);
                            }
                        });
                    },
                    observerOptions,
                );

                document.querySelectorAll(".reveal-on-scroll").forEach((el) => {
                    observer.observe(el);
                });

                // Home page search logic (Dropdown)
                const searchInput = document.getElementById(
                    "product-search",
                ) as HTMLInputElement;
                const searchDropdown =
                    document.getElementById("search-dropdown");

                let allProducts: any[] = [];
                let isFetching = false;

                if (searchInput && searchDropdown) {
                    searchInput.addEventListener("focus", async () => {
                        if (allProducts.length === 0 && !isFetching) {
                            isFetching = true;
                            try {
                                const API_BASE_URL =
                                    import.meta.env.PUBLIC_API_URL ||
                                    "http://localhost:3000";
                                const res = await fetch(
                                    `${API_BASE_URL}/products?limit=1000`,
                                );
                                const json = await res.json();
                                if (json.success) {
                                    allProducts = json.data.filter(
                                        (p: any) => p.is_active,
                                    );
                                }
                            } catch (e) {
                                console.error(
                                    "Error fetching products for search",
                                    e,
                                );
                            }
                        }
                    });

                    searchInput.addEventListener("input", () => {
                        const term = searchInput.value.toLowerCase().trim();
                        if (term.length === 0) {
                            searchDropdown.style.display = "none";
                            return;
                        }

                        const matches = allProducts
                            .filter(
                                (p) =>
                                    (p.name &&
                                        p.name.toLowerCase().includes(term)) ||
                                    (p.brand &&
                                        p.brand.toLowerCase().includes(term)),
                            )
                            .slice(0, 6);

                        if (matches.length > 0) {
                            searchDropdown.innerHTML = matches
                                .map((p) => {
                                    const price =
                                        p.sale_price &&
                                        parseFloat(p.sale_price) <
                                            parseFloat(p.price)
                                            ? p.sale_price
                                            : p.price;
                                    return `
                                <a href="/product/${p.id}" class="search-result-item">
                                    <img src="${p.image_url}" alt="${p.name}">
                                    <div class="search-result-info">
                                        <span class="sr-brand">${p.brand || ""}</span>
                                        <span class="sr-name">${p.name}</span>
                                        <span class="sr-price">$${price}</span>
                                    </div>
                                </a>
                                `;
                                })
                                .join("");
                            searchDropdown.style.display = "block";
                        } else {
                            searchDropdown.innerHTML =
                                '<div class="sr-empty">No se encontraron productos</div>';
                            searchDropdown.style.display = "block";
                        }
                    });

                    document.addEventListener("click", (e) => {
                        const target = e.target as Node;
                        if (
                            !searchInput.contains(target) &&
                            !searchDropdown.contains(target)
                        ) {
                            searchDropdown.style.display = "none";
                        }
                    });
                }
            });
        </script>


<style is:global>
    /* Reset & Base */
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        background-color: #000;
        color: #fff;
        font-family: "Inter", sans-serif;
        overflow-x: hidden;
    }

    h1,
    h2,
    h3,
    .product-price {
        font-family: "Oswald", sans-serif;
        text-transform: uppercase;
    }

    /* Reveal Animations */
    .reveal-item {
        opacity: 0;
        transform: translateY(40px);
        transition:
            opacity 0.8s ease-out,
            transform 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
    }
    .reveal-on-scroll.is-visible .reveal-item {
        opacity: 1;
        transform: translateY(0);
    }

    /* Store Sections */
    .store-section {
        padding: 0 0 5rem 0;
        margin: 0 auto;
    }

    .store-features {
        padding: 6rem 0;
        background: linear-gradient(
            to bottom,
            transparent,
            rgba(255, 255, 255, 0.02)
        );
        border-top: 1px solid rgba(255, 255, 255, 0.05);
    }

    .features-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 2rem;
    }
    @media (min-width: 768px) {
        .features-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }
    @media (min-width: 1024px) {
        .features-grid {
            grid-template-columns: repeat(4, 1fr);
        }
    }

    .feature-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.05);
        padding: 2.5rem 2rem;
        border-radius: 12px;
        text-align: center;
        transition:
            transform 0.3s ease,
            background 0.3s ease;
    }

    .feature-card:hover {
        transform: translateY(-5px);
        background: rgba(255, 255, 255, 0.05);
    }

    .feature-icon {
        font-size: 2.5rem;
        margin-bottom: 1.5rem;
    }

    .feature-card h3 {
        font-size: 1.2rem;
        margin-bottom: 1rem;
        letter-spacing: 1px;
    }

    .feature-card p {
        font-size: 0.95rem;
        color: rgba(255, 255, 255, 0.6);
        line-height: 1.6;
    }
    .container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 5%;
    }
    .section-title {
        font-size: 2.5rem;
        letter-spacing: 2px;
    }

    /* Category Header */
    .category-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 2.5rem;
        border-bottom: 2px solid rgba(255, 255, 255, 0.1);
        padding-bottom: 1rem;
    }

    .category-link {
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        opacity: 0.7;
        font-weight: 400;
        text-decoration: none;
        color: #fff;
        transition: opacity 0.3s;
        margin-bottom: 0.5rem;
    }
    .category-link:hover {
        opacity: 1;
    }

    /* Products Grid */
    .products-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
    }
    @media (min-width: 768px) {
        .products-grid {
            grid-template-columns: repeat(4, 1fr);
        }
    }

    /* Layout & Sidebar */
    .shop-layout {
        display: flex;
        flex-direction: column;
        gap: 3rem;
    }

    @media (min-width: 900px) {
        .shop-layout {
            flex-direction: row;
            align-items: flex-start;
        }

        .shop-sidebar {
            width: 250px;
            flex-shrink: 0;
            position: sticky;
            top: 20px;
            z-index: 10;
        }

        .shop-content {
            flex-grow: 1;
            width: calc(100% - 250px - 3rem);
        }
    }

    .filter-group {
        margin-bottom: 2.5rem;
        background: rgba(255, 255, 255, 0.02);
        padding: 1.5rem;
        border-radius: 8px;
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .filter-title {
        font-family: "Oswald", sans-serif;
        font-size: 1.2rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 1.2rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    .category-list {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 0.8rem;
    }

    .category-list a {
        color: rgba(255, 255, 255, 0.6);
        text-decoration: none;
        transition:
            color 0.3s ease,
            padding-left 0.3s ease;
        display: block;
    }

    .category-list a:hover {
        color: #fff;
        padding-left: 5px;
    }

    .category-list a.active {
        color: #fff;
        font-weight: bold;
        border-left: 2px solid #fff;
        padding-left: 10px;
    }

    .search-wrapper input {
        width: 100%;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        color: #fff;
        padding: 0.5rem;
        border-radius: 4px;
        font-family: "Inter", sans-serif;
        outline: none;
    }

    .search-wrapper input:focus {
        border-color: rgba(255, 255, 255, 0.5);
    }

    .search-dropdown {
        position: absolute;
        top: 100%;
        left: 0;
        width: 100%;
        background: #111;
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 4px;
        margin-top: 5px;
        max-height: 400px;
        overflow-y: auto;
        display: none;
        z-index: 100;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    }

    .search-result-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 10px;
        text-decoration: none;
        color: #fff;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        transition: background 0.2s;
    }

    .search-result-item:hover {
        background: rgba(255, 255, 255, 0.05);
    }

    .search-result-item img {
        width: 40px;
        height: 40px;
        object-fit: cover;
        border-radius: 4px;
        background: #000;
    }

    .search-result-info {
        display: flex;
        flex-direction: column;
    }

    .sr-brand {
        font-size: 0.7rem;
        opacity: 0.5;
        text-transform: uppercase;
    }

    .sr-name {
        font-size: 0.85rem;
        font-weight: 600;
    }

    .sr-price {
        font-size: 0.8rem;
        color: #fff;
        font-family: "Oswald", sans-serif;
    }

    .sr-empty {
        padding: 15px;
        text-align: center;
        font-size: 0.9rem;
        opacity: 0.6;
    }
</style>
</BaseLayout>
