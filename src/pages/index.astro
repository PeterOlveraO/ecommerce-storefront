---
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

const API_BASE_URL = import.meta.env.PUBLIC_API_URL || "http://localhost:3000";
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Vapezone</title>
        <link rel="icon" type="image/x-icon" href="/favicon.png" />
        <link
            href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;700&family=Inter:wght@300;400&display=swap"
            rel="stylesheet"
        />
    </head>
    <body>
        <Navbar />

        <!-- Hero Carousel dinámico -->
        <div id="hero-carousel-wrapper">
            <!-- Skeleton mientras carga -->
            <div
                id="hero-skeleton"
                style="width:100%;height:420px;background:rgba(255,255,255,0.04);display:flex;align-items:center;justify-content:center;"
            >
                <span
                    style="color:rgba(255,255,255,0.2);font-family:Inter,sans-serif;"
                    >Cargando...</span
                >
            </div>
            <div id="hero-carousel-content" style="display:none;"></div>
        </div>

        <div class="shop-layout container" style="margin-top: 4rem;">
            <aside class="shop-sidebar">
                <div class="filter-group">
                    <h3 class="filter-title">Buscar Producto</h3>
                    <div class="search-wrapper" style="position: relative;">
                        <input
                            type="text"
                            id="product-search"
                            placeholder="Escribe para buscar..."
                            autocomplete="off"
                        />
                        <div id="search-dropdown" class="search-dropdown"></div>
                    </div>
                </div>

                <div class="filter-group">
                    <h3 class="filter-title">Categorías</h3>
                    <ul class="category-list" id="category-list">
                        <li><a href="/" class="active">Inicio</a></li>
                        <!-- Se llena dinámicamente -->
                    </ul>
                </div>
            </aside>

            <div class="shop-content" id="shop-content">
                <!-- Skeleton productos -->
                <div id="products-skeleton">
                    {
                        [1, 2, 3].map(() => (
                            <section style="margin-bottom:4rem;">
                                <div style="height:2rem;width:200px;background:rgba(255,255,255,0.06);border-radius:4px;margin-bottom:2rem;" />
                                <div style="display:grid;grid-template-columns:repeat(2,1fr);gap:1.5rem;">
                                    {[1, 2, 3, 4].map(() => (
                                        <div style="height:280px;background:rgba(255,255,255,0.04);border-radius:8px;" />
                                    ))}
                                </div>
                            </section>
                        ))
                    }
                </div>
                <!-- Contenido real -->
                <div id="categories-content" style="display:none;"></div>
            </div>
        </div>

        <!-- Features -->
        <section class="store-features reveal-on-scroll">
            <div class="container">
                <div class="features-grid">
                    <div class="feature-card reveal-item">
                        <div class="feature-icon">🇲🇽</div>
                        <h3>Envíos a todo México</h3>
                        <p>
                            Recibe tus productos de forma rápida y confiable en
                            cualquier rincón del país.
                        </p>
                    </div>
                    <div
                        class="feature-card reveal-item"
                        style="transition-delay: 100ms"
                    >
                        <div class="feature-icon">🔒</div>
                        <h3>Compra Segura</h3>
                        <p>
                            Tus transacciones y datos están protegidos en todo
                            momento para tu total tranquilidad.
                        </p>
                    </div>
                    <div
                        class="feature-card reveal-item"
                        style="transition-delay: 200ms"
                    >
                        <div class="feature-icon">💬</div>
                        <h3>Soporte vía Discord</h3>
                        <p>
                            Atención rápida y personalizada. Únete a nuestra
                            comunidad para aclarar cualquier duda.
                        </p>
                    </div>
                    <div
                        class="feature-card reveal-item"
                        style="transition-delay: 300ms"
                    >
                        <div class="feature-icon">⚠️</div>
                        <h3>Política de Ventas</h3>
                        <p>
                            Garantizamos productos nuevos y sellados. Por
                            motivos de higiene y seguridad, no manejamos
                            devoluciones.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <Footer />

        <script define:vars={{ API_BASE_URL }}>
            const defaultColors = ["#ff4d88", "#4d88ff", "#4dff88", "#b34dff"];

            // ─── Render Hero Carousel ───────────────────────────────
            function renderHero(slides) {
                if (!slides.length) return;
                const wrapper = document.getElementById(
                    "hero-carousel-content",
                );
                const skeleton = document.getElementById("hero-skeleton");
                wrapper.innerHTML = `
                <div class="hero-slider" id="heroSlider">
                    ${slides
                        .map(
                            (s, i) => `
                        <div class="hero-slide ${i === 0 ? "active" : ""}" style="background:${s.color}20;">
                            <div class="hero-content">
                                <span class="hero-tagline">${s.tagline}</span>
                                <h1 class="hero-title">${s.name}</h1>
                                ${
                                    s.price
                                        ? `<div class="hero-price">
                                    ${s.original_price ? `<span class="hero-price-original">$${s.original_price}</span>` : ""}
                                    <span class="hero-price-main">$${s.price}</span>
                                </div>`
                                        : ""
                                }
                                <a href="${s.link}" class="hero-cta">
                                    ${s.is_product ? "Ver Producto" : "Ver más"}
                                </a>
                            </div>
                            <div class="hero-image-wrap">
                                <img src="${s.image}" alt="${s.name}" />
                            </div>
                        </div>
                    `,
                        )
                        .join("")}
                    <button class="hero-arrow prev" id="heroPrev">&#8249;</button>
                    <button class="hero-arrow next" id="heroNext">&#8250;</button>
                    <div class="hero-dots">
                        ${slides.map((_, i) => `<span class="hero-dot ${i === 0 ? "active" : ""}" data-i="${i}"></span>`).join("")}
                    </div>
                </div>`;

                skeleton.style.display = "none";
                wrapper.style.display = "block";
                initSlider(slides.length);
            }

            function initSlider(total) {
                let current = 0;
                const slides = document.querySelectorAll(".hero-slide");
                const dots = document.querySelectorAll(".hero-dot");

                function goTo(n) {
                    slides[current].classList.remove("active");
                    dots[current].classList.remove("active");
                    current = (n + total) % total;
                    slides[current].classList.add("active");
                    dots[current].classList.add("active");
                }

                document
                    .getElementById("heroPrev")
                    .addEventListener("click", () => goTo(current - 1));
                document
                    .getElementById("heroNext")
                    .addEventListener("click", () => goTo(current + 1));
                dots.forEach((d) =>
                    d.addEventListener("click", () => goTo(+d.dataset.i)),
                );
                setInterval(() => goTo(current + 1), 5000);
            }

            // ─── Render categorías y productos ─────────────────────
            function renderProductCard(product, index) {
                const price =
                    product.sale_price &&
                    parseFloat(product.sale_price) < parseFloat(product.price)
                        ? product.sale_price
                        : product.price;
                const hasDiscount =
                    product.sale_price &&
                    parseFloat(product.sale_price) < parseFloat(product.price);
                return `
                <a href="/product/${product.id}" class="product-card reveal-item" style="transition-delay:${index * 80}ms;text-decoration:none;color:inherit;">
                    <div class="product-img-wrap">
                        <img src="${product.image_url}" alt="${product.name}" loading="lazy" />
                    </div>
                    <div class="product-info">
                        <span class="product-brand">${product.brand || ""}</span>
                        <h3 class="product-name">${product.name}</h3>
                        <div class="product-price-wrap">
                            ${hasDiscount ? `<span class="product-price-old">$${product.price}</span>` : ""}
                            <span class="product-price">$${price}</span>
                        </div>
                    </div>
                </a>`;
            }

            function renderCategories(categories) {
                const container = document.getElementById("categories-content");
                const skeleton = document.getElementById("products-skeleton");
                container.innerHTML = categories
                    .map(
                        (cat) => `
                <section class="store-section reveal-on-scroll">
                    <div class="category-header reveal-item">
                        <h2 class="section-title">${cat.name}</h2>
                        <a href="/category/${cat.id}" class="category-link">
                            Ver todo
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                <path d="M5 12h14M12 5l7 7-7 7"/>
                            </svg>
                        </a>
                    </div>
                    <div class="products-grid">
                        ${cat.products.map((p, i) => renderProductCard(p, i)).join("")}
                    </div>
                </section>
            `,
                    )
                    .join("");

                skeleton.style.display = "none";
                container.style.display = "block";
                initScrollReveal();
            }

            function renderCategoryList(categories) {
                const list = document.getElementById("category-list");
                const extras = categories
                    .map(
                        (cat) =>
                            `<li><a href="/category/${cat.id}">${cat.name}</a></li>`,
                    )
                    .join("");
                list.innerHTML = `<li><a href="/" class="active">Inicio</a></li>${extras}`;
            }

            // ─── Scroll reveal ──────────────────────────────────────
            function initScrollReveal() {
                const observer = new IntersectionObserver(
                    (entries, obs) => {
                        entries.forEach((entry) => {
                            if (entry.isIntersecting) {
                                entry.target.classList.add("is-visible");
                                obs.unobserve(entry.target);
                            }
                        });
                    },
                    { threshold: 0.15 },
                );
                document
                    .querySelectorAll(".reveal-on-scroll")
                    .forEach((el) => observer.observe(el));
            }

            // ─── Search ─────────────────────────────────────────────
            function initSearch() {
                const searchInput = document.getElementById("product-search");
                const searchDropdown =
                    document.getElementById("search-dropdown");
                let allProducts = [];
                let isFetching = false;

                searchInput.addEventListener("focus", async () => {
                    if (allProducts.length === 0 && !isFetching) {
                        isFetching = true;
                        try {
                            const res = await fetch(
                                `${API_BASE_URL}/products?limit=1000`,
                            );
                            const json = await res.json();
                            if (json.success)
                                allProducts = json.data.filter(
                                    (p) => p.is_active,
                                );
                        } catch (e) {
                            console.error(e);
                        }
                    }
                });

                searchInput.addEventListener("input", () => {
                    const term = searchInput.value.toLowerCase().trim();
                    if (!term) {
                        searchDropdown.style.display = "none";
                        return;
                    }
                    const matches = allProducts
                        .filter(
                            (p) =>
                                (p.name &&
                                    p.name.toLowerCase().includes(term)) ||
                                (p.brand &&
                                    p.brand.toLowerCase().includes(term)),
                        )
                        .slice(0, 6);

                    if (matches.length) {
                        searchDropdown.innerHTML = matches
                            .map((p) => {
                                const price =
                                    p.sale_price &&
                                    parseFloat(p.sale_price) <
                                        parseFloat(p.price)
                                        ? p.sale_price
                                        : p.price;
                                return `<a href="/product/${p.id}" class="search-result-item">
                            <img src="${p.image_url}" alt="${p.name}">
                            <div class="search-result-info">
                                <span class="sr-brand">${p.brand || ""}</span>
                                <span class="sr-name">${p.name}</span>
                                <span class="sr-price">$${price}</span>
                            </div>
                        </a>`;
                            })
                            .join("");
                    } else {
                        searchDropdown.innerHTML =
                            '<div class="sr-empty">No se encontraron productos</div>';
                    }
                    searchDropdown.style.display = "block";
                });

                document.addEventListener("click", (e) => {
                    if (
                        !searchInput.contains(e.target) &&
                        !searchDropdown.contains(e.target)
                    )
                        searchDropdown.style.display = "none";
                });
            }

            // ─── Main: fetch todo ───────────────────────────────────
            async function init() {
                try {
                    // Header images
                    const headerRes = await fetch(
                        `${API_BASE_URL}/header-images`,
                    );
                    if (headerRes.ok) {
                        const result = await headerRes.json();
                        if (result.success && result.data) {
                            const activeHeaders = result.data
                                .filter((img) => img.is_active)
                                .sort(
                                    (a, b) => a.display_order - b.display_order,
                                );

                            const slides = await Promise.all(
                                activeHeaders.map(async (img, index) => {
                                    let productData = null;
                                    let isProductLink = false;
                                    let linkUrl = img.link_url || "";

                                    if (linkUrl.includes("product/")) {
                                        isProductLink = true;
                                        const productId = linkUrl
                                            .split("product/")[1]
                                            ?.replace(/^\//, "");
                                        if (productId) {
                                            try {
                                                const r = await fetch(
                                                    `${API_BASE_URL}/products/${productId}`,
                                                );
                                                if (r.ok) {
                                                    const j = await r.json();
                                                    if (j.success && j.data)
                                                        productData = j.data;
                                                }
                                            } catch (e) {}
                                        }
                                    }

                                    return {
                                        name: productData
                                            ? productData.name
                                            : img.name || "Promo",
                                        tagline: productData
                                            ? productData.brand
                                            : isProductLink
                                              ? "Destacado"
                                              : "Novedad",
                                        price: productData
                                            ? productData.sale_price ||
                                              productData.price
                                            : "",
                                        original_price: productData
                                            ? productData.sale_price
                                                ? productData.price
                                                : ""
                                            : "",
                                        image: img.image_url,
                                        color: defaultColors[
                                            index % defaultColors.length
                                        ],
                                        link: linkUrl.startsWith("/")
                                            ? linkUrl
                                            : `/${linkUrl}`,
                                        is_product: isProductLink,
                                    };
                                }),
                            );
                            renderHero(slides);
                        }
                    }

                    // Categorías y productos
                    const catRes = await fetch(`${API_BASE_URL}/categories`);
                    if (catRes.ok) {
                        const catResult = await catRes.json();
                        if (catResult.success && catResult.data) {
                            const activeCats = catResult.data
                                .filter(
                                    (cat) =>
                                        cat.is_active && cat.display_order >= 1,
                                )
                                .sort(
                                    (a, b) => a.display_order - b.display_order,
                                );

                            renderCategoryList(activeCats);

                            for (let cat of activeCats) {
                                const r = await fetch(
                                    `${API_BASE_URL}/products?category_id=${cat.id}&limit=50`,
                                );
                                if (r.ok) {
                                    const j = await r.json();
                                    cat.products =
                                        j.success && j.data
                                            ? j.data
                                                  .filter(
                                                      (p) =>
                                                          p.is_active &&
                                                          p.featured != 1 &&
                                                          p.featured !== true &&
                                                          p.featured !== "1",
                                                  )
                                                  .sort(
                                                      (a, b) =>
                                                          a.display_order -
                                                          b.display_order,
                                                  )
                                                  .slice(0, 4)
                                            : [];
                                } else {
                                    cat.products = [];
                                }
                            }

                            const categories = activeCats
                                .filter(
                                    (cat) =>
                                        cat.products && cat.products.length > 0,
                                )
                                .slice(0, 5);
                            renderCategories(categories);
                        }
                    }
                } catch (e) {
                    console.error("Error cargando home:", e);
                }
            }

            document.addEventListener("DOMContentLoaded", () => {
                init();
                initSearch();
                initScrollReveal();
            });
        </script>
    </body>
</html>

<!-- TU MISMO <style> QUE YA TENÍAS — no cambia nada -->
