---
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>Registro - Vapezone</title>
        <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />
        <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;700&family=Inter:wght@300;400&display=swap" rel="stylesheet" />
    </head>
    <body>
        <Navbar solid={true} />
        <div class="auth-container">
            <div class="auth-card reveal-item">
                <h1>CREAR CUENTA</h1>
                <p>Únete para poder realizar compras y guardar tus datos.</p>
                <form id="register-form" class="auth-form">
                    <!-- Credenciales -->
                    <h3>Credenciales</h3>
                    <div class="form-row">
                        <div class="form-group half">
                            <label for="name">Nombres</label>
                            <input type="text" id="first_name" name="first_name" required placeholder="Juan" />
                        </div>
                        <div class="form-group half">
                            <label for="name">Apellidos</label>
                            <input type="text" id="last_name" name="last_name" required placeholder="Pérez" />
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group half">
                            <label for="email">Correo Electrónico</label>
                            <input type="email" id="email" name="email" required placeholder="tu@email.com" />
                        </div>
                        <div class="form-group half">
                            <label for="password">Contraseña</label>
                            <input type="password" id="password" name="password" required placeholder="••••••••" minlength="6" />
                        </div>
                    </div>

                    <!-- Datos de Envío -->
                    <h3 class="mt-4">Datos de Envío</h3>
                    <div class="form-group">
                        <label for="phone_contact">Teléfono de Contacto</label>
                        <input type="text" id="phone_contact" name="phone_contact" required placeholder="10 dígitos" minlength="7" />
                    </div>
                    <div class="form-row">
                        <div class="form-group half">
                            <label for="street_address">Calle</label>
                            <input type="text" id="street_address" name="street_address" required placeholder="Av. Siempre Viva" />
                        </div>
                        <div class="form-group half">
                            <label for="exterior_number">Núm Exterior</label>
                            <input type="text" id="exterior_number" name="exterior_number" required placeholder="123" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label for="neighborhood">Colonia / Barrio (Opcional)</label>
                        <input type="text" id="neighborhood" name="neighborhood" placeholder="Centro" />
                    </div>
                    <div class="form-row">
                        <div class="form-group third">
                            <label for="postal_code">C.P.</label>
                            <input type="text" id="postal_code" name="postal_code" required placeholder="00000" />
                        </div>
                        <div class="form-group third">
                            <label for="city">Ciudad</label>
                            <input type="text" id="city" name="city" required placeholder="Ej. Monterrey" />
                        </div>
                        <div class="form-group third">
                            <label for="state">Estado</label>
                            <input type="text" id="state" name="state" required placeholder="Ej. Nuevo León" />
                        </div>
                    </div>

                    <button type="submit" id="submit-btn" class="submit-btn">REGISTRARSE</button>
                    <div id="auth-message" class="auth-message"></div>
                </form>
                <p class="switch-auth">¿Ya tienes cuenta? <a href="/login">Inicia sesión</a></p>
            </div>
        </div>
        <Footer />
        <script>
            document.addEventListener('DOMContentLoaded', () => {
                const card = document.querySelector('.auth-card');
                setTimeout(() => card?.classList.add('visible'), 100);

                const form = document.getElementById('register-form');
                const msg = document.getElementById('auth-message');
                const btn = document.getElementById('submit-btn');
                
                const API_BASE_URL = import.meta.env.PUBLIC_API_URL || "http://localhost:3000";

                form?.addEventListener('submit', async (e) => {
                    e.preventDefault();
                    if(btn) (btn as HTMLButtonElement).disabled = true;
                    if(msg) { msg.textContent = 'Procesando...'; msg.className = 'auth-message loading'; }

                    const first_name = (document.getElementById('first_name') as HTMLInputElement).value;
                    const last_name = (document.getElementById('last_name') as HTMLInputElement).value;
                    const email = (document.getElementById('email') as HTMLInputElement).value;
                    const password = (document.getElementById('password') as HTMLInputElement).value;
                    const phone_contact = (document.getElementById('phone_contact') as HTMLInputElement).value;
                    const street_address = (document.getElementById('street_address') as HTMLInputElement).value;
                    const exterior_number = (document.getElementById('exterior_number') as HTMLInputElement).value;
                    const neighborhood = (document.getElementById('neighborhood') as HTMLInputElement).value;
                    const postal_code = (document.getElementById('postal_code') as HTMLInputElement).value;
                    const city = (document.getElementById('city') as HTMLInputElement).value;
                    const state = (document.getElementById('state') as HTMLInputElement).value;

                    const payload = {
                        email,
                        password,
                        first_name,
                        last_name,
                        street_address,
                        exterior_number,
                        neighborhood,
                        postal_code,
                        city,
                        state,
                        phone_contact
                    };

                    try {
                        const res = await fetch(`${API_BASE_URL}/register`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(payload)
                        });
                        const data = await res.json();

                        if (res.ok && (data.success || data.data)) {
                            if(msg) { msg.textContent = 'Registro exitoso. Por favor inicia sesión.'; msg.className = 'auth-message success'; }
                            setTimeout(() => {
                                const urlParams = new URLSearchParams(window.location.search);
                                const redirect = urlParams.get('redirect');
                                window.location.href = `/login${redirect ? '?redirect='+redirect : ''}`;
                            }, 1500);
                        } else {
                            throw new Error(data.message || 'Error en el registro');
                        }
                    } catch (error: any) {
                        console.error("API Error:", error);
                        if(msg) { msg.textContent = error.message || 'Error al conectar con el servidor.'; msg.className = 'auth-message error'; }
                        if(btn) (btn as HTMLButtonElement).disabled = false;
                    }
                });
            });
        </script>
    </body>
</html>

<style is:global>
    body {
        background-color: #000;
        color: #fff;
        font-family: "Inter", sans-serif;
        margin: 0;
    }
    
    .auth-container {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 6rem 1rem 2rem 1rem;
        background: linear-gradient(to bottom, #111, #000);
    }

    .auth-card {
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.05);
        padding: 3rem 2rem;
        border-radius: 12px;
        width: 100%;
        max-width: 450px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.5s ease, transform 0.5s ease;
    }

    .auth-card.visible {
        opacity: 1;
        transform: translateY(0);
    }

    .auth-card h1 {
        font-family: "Oswald", sans-serif;
        font-size: 2.5rem;
        text-align: center;
        margin-bottom: 0.5rem;
        letter-spacing: 2px;
        color: #fff;
    }

    .auth-card > p {
        text-align: center;
        color: rgba(255,255,255,0.6);
        margin-bottom: 2rem;
        font-size: 0.95rem;
    }

    .auth-card h3 {
        font-family: "Oswald", sans-serif;
        font-size: 1.2rem;
        margin-bottom: 1rem;
        color: rgba(255,255,255,0.9);
        border-bottom: 1px solid rgba(255,255,255,0.1);
        padding-bottom: 0.5rem;
    }

    .mt-4 {
        margin-top: 1.5rem;
    }

    .form-row {
        display: flex;
        gap: 1rem;
        margin-bottom: 1.5rem;
    }
    
    .form-row .form-group {
        margin-bottom: 0;
    }

    .form-group.half {
        flex: 1;
    }

    .form-group.third {
        flex: 1;
    }

    .form-group {
        margin-bottom: 1.5rem;
    }

    .form-group label {
        display: block;
        margin-bottom: 0.5rem;
        font-size: 0.9rem;
        color: rgba(255,255,255,0.8);
    }

    .form-group input {
        width: 100%;
        padding: 0.8rem 1rem;
        background: rgba(0,0,0,0.5);
        border: 1px solid rgba(255,255,255,0.2);
        color: #fff;
        border-radius: 4px;
        font-family: "Inter", sans-serif;
        transition: border-color 0.3s;
        box-sizing: border-box;
    }

    .form-group input:focus {
        outline: none;
        border-color: #fff;
    }

    .submit-btn {
        width: 100%;
        padding: 1rem;
        background: #fff;
        color: #000;
        border: none;
        font-family: "Oswald", sans-serif;
        font-size: 1.1rem;
        font-weight: 700;
        cursor: pointer;
        transition: background 0.3s, transform 0.3s;
        border-radius: 4px;
        margin-top: 1rem;
    }

    .submit-btn:hover {
        background: #f0f0f0;
        transform: translateY(-2px);
    }

    .submit-btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
        transform: none;
    }

    .auth-message {
        margin-top: 1rem;
        text-align: center;
        font-size: 0.9rem;
        min-height: 20px;
    }

    .auth-message.error {
        color: #f44336;
    }

    .auth-message.success {
        color: #4caf50;
    }

    .auth-message.loading {
        color: rgba(255,255,255,0.6);
    }

    .switch-auth {
        text-align: center;
        margin-top: 2rem;
        font-size: 0.9rem;
        color: rgba(255,255,255,0.6);
    }

    .switch-auth a {
        color: #fff;
        text-decoration: underline;
    }
</style>
