---
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import ProductCard from "../../components/ProductCard.astro";

export async function getStaticPaths() {
    const API_BASE_URL =
        import.meta.env.PUBLIC_API_URL || "http://localhost:3000";
    try {
        const res = await fetch(`${API_BASE_URL}/products?limit=1000`);
        if (!res.ok) return [];
        const result = await res.json();
        if (!result.success || !result.data) return [];

        return result.data.map((product: any) => ({
            params: { id: product.id },
            props: { product },
        }));
    } catch (e) {
        console.error("Error fetching products for paths", e);
        return [];
    }
}

const { product: basicProduct } = Astro.props;
const API_BASE_URL = import.meta.env.PUBLIC_API_URL || "http://localhost:3000";

// Fetch full product details including variants y categorías
let fullProduct = basicProduct;
let relatedProducts: any[] = [];
let categoryId: string | null = null; // 👈 agregar aquí fuera

try {
    const res = await fetch(`${API_BASE_URL}/products/${basicProduct.id}`);
    if (res.ok) {
        const json = await res.json();
        if (json.success && json.data) {
            fullProduct = json.data;

            // Sacar el category_id desde las categorías que ya devuelve /products/:id
            const cats = fullProduct.categories;
            let categoryId = null;
            const parsedCats =
                typeof cats === "string" ? JSON.parse(cats) : cats;

            if (Array.isArray(parsedCats) && parsedCats.length > 0) {
                categoryId = parsedCats[0]?.id ?? null;
            }

            // Fetch productos de la misma categoría
            if (categoryId) {
                try {
                    const relRes = await fetch(
                        `${API_BASE_URL}/products?category_id=${categoryId}&limit=5`,
                    );
                    if (relRes.ok) {
                        const relJson = await relRes.json();
                        if (relJson.success && relJson.data) {
                            relatedProducts = relJson.data
                                .filter(
                                    (p: any) =>
                                        String(p.id) !==
                                        String(basicProduct.id),
                                )
                                .slice(0, 4);
                        }
                    }
                } catch (e) {
                    console.error("Error fetching related products", e);
                }
            }
        }
    }
} catch (e) {
    console.error("Error fetching full product details", e);
}

const product = fullProduct;

let productDetails = null;
if (product.details) {
    try {
        productDetails =
            typeof product.details === "string"
                ? JSON.parse(product.details)
                : product.details;
    } catch (e) {
        console.error("Could not parse product details", e);
    }
}

const activeVariants = (product.variants || []).filter((v: any) => v.is_active);

// Preparar imágenes de la galería
const allImages: string[] = [];
const getFullUrl = (url: string) => {
    if (!url) return "";
    if (url.startsWith("http")) return url;
    return `${API_BASE_URL}${url.startsWith("/") ? "" : "/"}${url}`;
};

if (product.image_url) {
    allImages.push(getFullUrl(product.image_url));
}
if (Array.isArray(product.images)) {
    product.images.forEach((img: string) => {
        if (img) allImages.push(getFullUrl(img));
    });
}
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{product.name} | Ecommerce Angel</title>
        <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" />
        <link
            href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;700&family=Inter:wght@300;400&display=swap"
            rel="stylesheet"
        />
    </head>
    <body>
        <Navbar solid={true} />

        <div class="back-bar">
            <button
                id="back-btn"
                class="back-btn"
                onclick="history.length > 1 ? history.back() : window.location.href = '/'"
            >
                <svg
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                >
                    <path d="M19 12H5M12 5l-7 7 7 7"></path>
                </svg>
                Regresar
            </button>
        </div>

        <main class="product-page">
            <div class="product-container">
                <div class="product-image-col reveal-item">
                    <div class="image-wrapper">
                        {
                            product.sale_price &&
                                parseFloat(product.sale_price) <
                                    parseFloat(product.price) && (
                                    <span class="sale-badge">Oferta</span>
                                )
                        }
                        <img
                            id="main-product-image"
                            src={allImages.length > 0
                                ? allImages[0]
                                : product.image_url}
                            alt={product.name}
                        />

                        {
                            allImages.length > 1 && (
                                <>
                                    <button
                                        type="button"
                                        class="gallery-nav prev"
                                        aria-label="Anterior imagen"
                                    >
                                        <svg
                                            width="24"
                                            height="24"
                                            viewBox="0 0 24 24"
                                            fill="none"
                                            stroke="currentColor"
                                            stroke-width="2"
                                        >
                                            <path d="M15 18l-6-6 6-6" />
                                        </svg>
                                    </button>
                                    <button
                                        type="button"
                                        class="gallery-nav next"
                                        aria-label="Siguiente imagen"
                                    >
                                        <svg
                                            width="24"
                                            height="24"
                                            viewBox="0 0 24 24"
                                            fill="none"
                                            stroke="currentColor"
                                            stroke-width="2"
                                        >
                                            <path d="M9 18l6-6-6-6" />
                                        </svg>
                                    </button>
                                </>
                            )
                        }
                    </div>

                    {
                        allImages.length > 1 && (
                            <div class="product-gallery">
                                {allImages.map((img: string, index: number) => (
                                    <button
                                        type="button"
                                        class={`gallery-thumbnail ${index === 0 ? "active" : ""}`}
                                        data-image={img}
                                        aria-label={`Ver imagen ${index + 1}`}
                                    >
                                        <img
                                            src={img}
                                            alt={`${product.name} - Vista ${index + 1}`}
                                            loading="lazy"
                                        />
                                    </button>
                                ))}
                            </div>
                        )
                    }
                </div>

                <div class="product-info-col reveal-item">
                    <p class="brand">{product.brand}</p>
                    <h1 class="title">{product.name}</h1>

                    <div class="price-container">
                        {
                            product.sale_price &&
                            parseFloat(product.sale_price) <
                                parseFloat(product.price) ? (
                                <>
                                    <span class="current-price">
                                        ${product.sale_price}
                                    </span>
                                    <span class="original-price">
                                        ${product.price}
                                    </span>
                                </>
                            ) : (
                                <span class="current-price">
                                    ${product.price}
                                </span>
                            )
                        }
                    </div>

                    <div class="description">
                        <p>{product.description}</p>
                    </div>

                    {
                        activeVariants.length > 0 && (
                            <div class="product-variants">
                                <h3 class="variants-title">
                                    Selecciona una opción:
                                </h3>
                                <div
                                    class="variants-grid"
                                    id="variants-container"
                                >
                                    {activeVariants.map((variant: any) => {
                                        const isOutOfStock =
                                            variant.stock === 0;
                                        return (
                                            <button
                                                class={`variant-btn ${isOutOfStock ? "disabled" : ""}`}
                                                data-id={variant.id}
                                                data-name={
                                                    variant.variante1 +
                                                    (variant.variante2
                                                        ? ` - ${variant.variante2}`
                                                        : "")
                                                }
                                                data-stock={variant.stock}
                                                disabled={isOutOfStock}
                                            >
                                                {variant.variante1}
                                                {variant.variante2 &&
                                                    ` - ${variant.variante2}`}
                                                {isOutOfStock && " (Agotado)"}
                                            </button>
                                        );
                                    })}
                                </div>
                                <p
                                    id="variant-error"
                                    class="variant-error"
                                    style="display: none; color: #ff4d4d; margin-top: 10px;"
                                >
                                    Por favor, selecciona una opción antes de
                                    añadir al carrito.
                                </p>
                            </div>
                        )
                    }

                    {
                        productDetails &&
                            Object.keys(productDetails).length > 0 && (
                                <div class="product-details">
                                    <h3 class="details-title">
                                        Especificaciones
                                    </h3>
                                    <ul class="details-list">
                                        {Object.entries(productDetails).map(
                                            ([key, value]) => (
                                                <li>
                                                    <span class="detail-key">
                                                        {key}:
                                                    </span>
                                                    <span class="detail-value">
                                                        {value}
                                                    </span>
                                                </li>
                                            ),
                                        )}
                                    </ul>
                                </div>
                            )
                    }

                    <button
                        id="add-to-cart-btn"
                        class="add-to-cart-btn"
                        data-product={JSON.stringify({
                            id: product.id,
                            name: product.name,
                            brand: product.brand,
                            price:
                                product.sale_price &&
                                parseFloat(product.sale_price) <
                                    parseFloat(product.price)
                                    ? product.sale_price
                                    : product.price,
                            image_url: product.image_url,
                            stock: product.stock,
                        })}
                    >
                        AÑADIR AL CARRITO
                    </button>
                </div>
            </div>
        </main>

        {
            relatedProducts.length > 0 && (
                <div class="related-wrapper container">
                    <section class="store-section reveal-on-scroll">
                        <div class="category-header reveal-item">
                            <h2 class="section-title">
                                También te puede gustar
                            </h2>
                            <a
                                href={`/category/${categoryId}`}
                                class="category-link"
                            >
                                Ver todo{" "}
                                <svg
                                    width="16"
                                    height="16"
                                    viewBox="0 0 24 24"
                                    fill="none"
                                    stroke="currentColor"
                                    stroke-width="2"
                                >
                                    <path d="M5 12h14M12 5l7 7-7 7" />
                                </svg>
                            </a>
                        </div>
                        <div class="products-grid">
                            {relatedProducts.map((rp: any, index: number) => (
                                <ProductCard product={rp} index={index} />
                            ))}
                        </div>
                    </section>
                </div>
            )
        }

        <Footer />

        <script>
            // Reveal animation — igual que index.astro
            document.addEventListener("DOMContentLoaded", () => {
                // Animar los .reveal-item del producto inmediatamente
                setTimeout(() => {
                    document
                        .querySelectorAll(".product-page .reveal-item")
                        .forEach((el, index) => {
                            setTimeout(() => {
                                el.classList.add("is-visible");
                            }, index * 200);
                        });
                }, 100);

                // Animar la sección de productos relacionados con IntersectionObserver
                // (igual que index.astro)
                // Animar la sección de productos relacionados con IntersectionObserver
                const observer = new IntersectionObserver(
                    (entries, obs) => {
                        entries.forEach((entry) => {
                            if (entry.isIntersecting) {
                                entry.target.classList.add("is-visible");
                                // Añadir is-visible directamente a cada hijo con stagger
                                entry.target
                                    .querySelectorAll(".reveal-item")
                                    .forEach((item, i) => {
                                        setTimeout(() => {
                                            (item as HTMLElement).classList.add(
                                                "is-visible",
                                            );
                                        }, i * 150);
                                    });
                                obs.unobserve(entry.target);
                            }
                        });
                    },
                    {
                        root: null,
                        rootMargin: "0px 0px -80px 0px",
                        threshold: 0.05,
                    },
                );
                document.querySelectorAll(".reveal-on-scroll").forEach((el) => {
                    observer.observe(el);
                });

                // Lógica de Galería de Imágenes
                const mainImage = document.getElementById(
                    "main-product-image",
                ) as HTMLImageElement;
                const thumbnails =
                    document.querySelectorAll(".gallery-thumbnail");
                const prevBtn = document.querySelector(".gallery-nav.prev");
                const nextBtn = document.querySelector(".gallery-nav.next");
                let currentImageIndex = 0;
                let autoSlideInterval: number | undefined;

                if (mainImage && thumbnails.length > 1) {
                    const updateImage = (index: number) => {
                        thumbnails.forEach((t) => t.classList.remove("active"));
                        thumbnails[index].classList.add("active");
                        const newSrc =
                            thumbnails[index].getAttribute("data-image");
                        if (newSrc) {
                            mainImage.style.opacity = "0.7";
                            setTimeout(() => {
                                mainImage.src = newSrc;
                                mainImage.style.opacity = "1";
                            }, 150);
                        }
                        currentImageIndex = index;
                    };

                    const nextImage = () => {
                        let nextIndex = currentImageIndex + 1;
                        if (nextIndex >= thumbnails.length) nextIndex = 0;
                        updateImage(nextIndex);
                    };

                    const prevImage = () => {
                        let prevIndex = currentImageIndex - 1;
                        if (prevIndex < 0) prevIndex = thumbnails.length - 1;
                        updateImage(prevIndex);
                    };

                    const startAutoSlide = () => {
                        clearInterval(autoSlideInterval);
                        autoSlideInterval = window.setInterval(nextImage, 4000);
                    };

                    thumbnails.forEach((thumb, index) => {
                        thumb.addEventListener("click", () => {
                            updateImage(index);
                            startAutoSlide(); // Reiniciar timer
                        });
                    });

                    if (prevBtn) {
                        prevBtn.addEventListener("click", (e) => {
                            e.preventDefault();
                            prevImage();
                            startAutoSlide();
                        });
                    }

                    if (nextBtn) {
                        nextBtn.addEventListener("click", (e) => {
                            e.preventDefault();
                            nextImage();
                            startAutoSlide();
                        });
                    }

                    // Pausar al hacer hover en la imagen principal
                    const imageWrapper =
                        document.querySelector(".image-wrapper");
                    if (imageWrapper) {
                        imageWrapper.addEventListener("mouseenter", () =>
                            clearInterval(autoSlideInterval),
                        );
                        imageWrapper.addEventListener(
                            "mouseleave",
                            startAutoSlide,
                        );
                    }

                    startAutoSlide();
                }

                // Variant Selection Logic
                let selectedVariantId = null;
                let selectedVariantName = null;
                const hasVariants =
                    document.querySelectorAll(".variant-btn").length > 0;
                const variantBtns = document.querySelectorAll(".variant-btn");
                const variantError = document.getElementById("variant-error");

                variantBtns.forEach((btn) => {
                    btn.addEventListener("click", () => {
                        variantBtns.forEach((b) =>
                            b.classList.remove("selected"),
                        );
                        btn.classList.add("selected");
                        selectedVariantId = btn.getAttribute("data-id");
                        selectedVariantName = btn.getAttribute("data-name");
                        if (variantError) variantError.style.display = "none";
                    });
                });

                // Add to Cart logic
                const addToCartBtn = document.getElementById("add-to-cart-btn");
                if (addToCartBtn) {
                    addToCartBtn.addEventListener("click", () => {
                        if (hasVariants && !selectedVariantId) {
                            if (variantError)
                                variantError.style.display = "block";
                            return;
                        }

                        const productData = JSON.parse(
                            addToCartBtn.dataset.product || "{}",
                        );

                        if (selectedVariantId) {
                            productData.variant_id = selectedVariantId;
                            // Append variant name to the product name for the cart display
                            productData.name = `${productData.name} - ${selectedVariantName}`;

                            // Override the product stock with the specific variant's stock
                            const variantBtn = document.querySelector(
                                `.variant-btn[data-id="${selectedVariantId}"]`,
                            );
                            if (variantBtn) {
                                productData.stock = parseInt(
                                    variantBtn.getAttribute("data-stock") ||
                                        "0",
                                    10,
                                );
                            }
                        }

                        if (window.addToCart) {
                            window.addToCart(productData);
                        }
                    });
                }
            });
        </script>
    </body>
</html>

<style>
    /* Back button */
    .back-bar {
        padding: 1.5rem 5%;
        max-width: 1400px;
        margin: 0 auto;
    }

    .back-btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: transparent;
        border: 1px solid rgba(255, 255, 255, 0.15);
        color: rgba(255, 255, 255, 0.7);
        padding: 0.55rem 1.1rem;
        border-radius: 6px;
        font-family: "Inter", sans-serif;
        font-size: 0.9rem;
        cursor: pointer;
        transition: all 0.25s ease;
        letter-spacing: 0.3px;
    }

    .back-btn:hover {
        border-color: rgba(255, 255, 255, 0.5);
        color: #fff;
        background: rgba(255, 255, 255, 0.05);
        transform: translateX(-2px);
    }

    /* Sección de productos relacionados — mismos estilos que index.astro */
    .related-wrapper {
        padding: 0 0 5rem 0;
        border-top: 1px solid rgba(255, 255, 255, 0.06);
        margin-top: 2rem;
    }

    .container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 5%;
    }

    .store-section {
        padding: 4rem 0 0 0;
    }

    .category-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        margin-bottom: 2.5rem;
        border-bottom: 2px solid rgba(255, 255, 255, 0.1);
        padding-bottom: 1rem;
    }

    .section-title {
        font-size: 2.5rem;
        letter-spacing: 2px;
        font-family: "Oswald", sans-serif;
        text-transform: uppercase;
    }

    .category-link {
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        opacity: 0.7;
        font-weight: 400;
        text-decoration: none;
        color: #fff;
        transition: opacity 0.3s;
        margin-bottom: 0.5rem;
    }

    .category-link:hover {
        opacity: 1;
    }

    .products-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
    }

    @media (min-width: 768px) {
        .products-grid {
            grid-template-columns: repeat(4, 1fr);
        }
    }

    /* Scoped styles */
    .product-page {
        padding: 1rem 5% 4rem;
        max-width: 1400px;
        margin: 0 auto;
        min-height: 60vh;
        display: flex;
        align-items: center;
    }

    .product-container {
        display: flex;
        flex-direction: column;
        gap: 4rem;
        width: 100%;
    }

    @media (min-width: 900px) {
        .product-container {
            flex-direction: row;
            align-items: center;
        }
        .product-image-col,
        .product-info-col {
            flex: 1;
        }
    }

    .product-image-col {
        position: relative;
    }

    .image-wrapper {
        position: relative;
        background: rgba(255, 255, 255, 0.03);
        border-radius: 12px;
        overflow: hidden;
        aspect-ratio: 4/5;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .image-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: opacity 0.3s ease;
    }

    .gallery-nav {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        background: rgba(0, 0, 0, 0.5);
        color: white;
        border: none;
        width: 40px;
        height: 40px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        opacity: 0;
        transition: all 0.3s ease;
        backdrop-filter: blur(4px);
    }

    .image-wrapper:hover .gallery-nav {
        opacity: 1;
    }

    .gallery-nav:hover {
        background: rgba(255, 255, 255, 0.2);
        transform: translateY(-50%) scale(1.1);
    }

    .gallery-nav.prev {
        left: 10px;
    }

    .gallery-nav.next {
        right: 10px;
    }

    .sale-badge {
        position: absolute;
        top: 20px;
        left: 20px;
        background: #fff;
        color: #000;
        padding: 6px 12px;
        font-size: 0.85rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        border-radius: 2px;
        z-index: 10;
        font-family: "Oswald", sans-serif;
    }

    /* Gallery Styles */
    .product-gallery {
        display: flex;
        gap: 1rem;
        margin-top: 1rem;
        overflow-x: auto;
        padding-bottom: 0.5rem;
        scrollbar-width: thin;
        scrollbar-color: rgba(255, 255, 255, 0.2) transparent;
    }

    .product-gallery::-webkit-scrollbar {
        height: 6px;
    }

    .product-gallery::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.2);
        border-radius: 3px;
    }

    .gallery-thumbnail {
        flex: 0 0 80px;
        height: 80px;
        border-radius: 8px;
        overflow: hidden;
        border: 2px solid transparent;
        cursor: pointer;
        background: rgba(255, 255, 255, 0.03);
        transition: all 0.3s ease;
        padding: 0;
    }

    .gallery-thumbnail img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .gallery-thumbnail:hover {
        border-color: rgba(255, 255, 255, 0.5);
    }

    .gallery-thumbnail.active {
        border-color: #fff;
    }

    .product-info-col {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .brand {
        font-size: 1.2rem;
        letter-spacing: 3px;
        opacity: 0.6;
        margin-bottom: -1rem;
        font-family: "Oswald", sans-serif;
        text-transform: uppercase;
    }

    .title {
        font-size: 3.5rem;
        line-height: 1.1;
        margin-bottom: 0.5rem;
        font-family: "Oswald", sans-serif;
        text-transform: uppercase;
    }

    .price-container {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        margin-bottom: 1rem;
    }

    .current-price {
        font-size: 2.5rem;
        font-weight: 700;
        font-family: "Oswald", sans-serif;
        text-transform: uppercase;
    }

    .original-price {
        font-size: 1.5rem;
        text-decoration: line-through;
        opacity: 0.5;
    }

    .description {
        font-size: 1.1rem;
        line-height: 1.8;
        opacity: 0.8;
        margin-bottom: 1rem;
    }

    /* Variants Styles */
    .product-variants {
        margin-bottom: 2rem;
    }

    .variants-title {
        font-size: 1.1rem;
        margin-bottom: 1rem;
        font-weight: 600;
    }

    .variants-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 0.8rem;
    }

    .variant-btn {
        background: transparent;
        border: 1px solid rgba(255, 255, 255, 0.3);
        color: #fff;
        padding: 0.8rem 1.2rem;
        border-radius: 6px;
        font-family: "Inter", sans-serif;
        font-size: 0.95rem;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .variant-btn:hover:not(.disabled) {
        border-color: #fff;
        background: rgba(255, 255, 255, 0.1);
    }

    .variant-btn.selected {
        border-color: #fff;
        background: #fff;
        color: #000;
        font-weight: 600;
    }

    .variant-btn.disabled {
        opacity: 0.3;
        cursor: not-allowed;
        text-decoration: line-through;
    }

    .add-to-cart-btn {
        background: #fff;
        color: #000;
        border: none;
        padding: 1.5rem 3rem;
        font-size: 1.2rem;
        font-weight: 700;
        letter-spacing: 2px;
        cursor: pointer;
