---
import BaseLayout from '../../layouts/BaseLayout.astro';

// En modo estático necesitamos exportar getStaticPaths.
// Retornamos vacío porque todas las rutas son dinámicas y se manejan
// en el cliente leyendo el ID desde window.location.pathname.
export function getStaticPaths() {
  return [];
}
---
<BaseLayout title="Categoría | Vapezone" navbarSolid={true}>

    <div class="back-bar">
        <button class="back-btn" onclick="history.length > 1 ? history.back() : window.location.href = '/'">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <path d="M19 12H5M12 5l-7 7 7 7"/>
            </svg>
            Regresar
        </button>
    </div>

    <!-- Loading state -->
    <div id="page-skeleton">
        <div class="skeleton-hero"></div>
        <div class="container" style="margin-top:2rem;">
            <div class="shop-layout">
                <div class="skeleton-sidebar">
                    <div class="skeleton-block"></div>
                    <div class="skeleton-block"></div>
                </div>
                <div style="flex:1;">
                    <div class="products-grid">
                        <div class="product-card-skeleton"></div>
                        <div class="product-card-skeleton"></div>
                        <div class="product-card-skeleton"></div>
                        <div class="product-card-skeleton"></div>
                        <div class="product-card-skeleton"></div>
                        <div class="product-card-skeleton"></div>
                        <div class="product-card-skeleton"></div>
                        <div class="product-card-skeleton"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Error state -->
    <div id="page-error" style="display:none;" class="full-error">
        <p>⚠️ No se pudo cargar esta categoría.</p>
        <button onclick="window.location.reload()">Reintentar</button>
    </div>

    <!-- Real content -->
    <main class="category-page" id="category-content" style="display:none;">
        <header class="category-hero">
            <h1 class="category-title reveal-item" id="category-title">Cargando...</h1>
            <p class="category-subtitle reveal-item" style="transition-delay: 0.1s;" id="category-subtitle"></p>
        </header>

        <div class="shop-layout container">
            <aside class="shop-sidebar reveal-item" style="transition-delay: 0.2s;">
                <div class="filter-group">
                    <h3 class="filter-title">Buscar Producto</h3>
                    <div class="search-wrapper" style="position: relative;">
                        <input type="text" id="product-search" placeholder="Escribe para buscar..." autocomplete="off" />
                        <div id="search-dropdown" class="search-dropdown"></div>
                    </div>
                </div>

                <div class="filter-group">
                    <h3 class="filter-title">Categorías</h3>
                    <ul class="category-list" id="category-list"></ul>
                </div>

                <div class="filter-group">
                    <h3 class="filter-title">Filtrar por Precio</h3>
                    <div class="price-inputs">
                        <input type="number" id="min-price" placeholder="Min $" min="0" />
                        <span>-</span>
                        <input type="number" id="max-price" placeholder="Max $" min="0" />
                    </div>
                    <button id="apply-price-btn" class="filter-btn">Aplicar Filtro</button>
                    <button id="reset-price-btn" class="filter-btn reset-btn">Restablecer</button>
                </div>
            </aside>

            <div class="shop-content">
                <div id="products-error" class="error-state" style="display:none;">
                    <p>⚠️ No se pudieron cargar los productos.</p>
                    <button onclick="window.location.reload()">Reintentar</button>
                </div>
                <div class="products-grid" id="products-grid"></div>
                <div id="empty-state" class="empty-state" style="display:none;">
                    <p>No hay productos disponibles en esta categoría por el momento.</p>
                </div>
            </div>
        </div>
    </main>

    <script>
        const API_BASE_URL = "https://api.vapezone.com.mx";

        // Get category ID from URL path: /category/123
        function getCategoryIdFromUrl(): string | null {
            const parts = window.location.pathname.split("/");
            const idx = parts.indexOf("category");
            if (idx !== -1 && parts[idx + 1]) return parts[idx + 1];
            return null;
        }

        async function initCategoryPage() {
            const skeleton = document.getElementById("page-skeleton");
            const pageError = document.getElementById("page-error");
            const content = document.getElementById("category-content");
            const titleEl = document.getElementById("category-title");
            const subtitleEl = document.getElementById("category-subtitle");
            const categoryListEl = document.getElementById("category-list");
            const productsGrid = document.getElementById("products-grid");
            const emptyState = document.getElementById("empty-state");
            const productsError = document.getElementById("products-error");

            const categoryId = getCategoryIdFromUrl();

            if (!categoryId) {
                window.location.href = "/";
                return;
            }

            try {
                // Fetch category info + all categories in parallel
                const [catRes, allCatRes] = await Promise.all([
                    fetch(`${API_BASE_URL}/categories/${categoryId}`),
                    fetch(`${API_BASE_URL}/categories?limit=1000`)
                ]);

                if (!catRes.ok) throw new Error("category not found");

                const catResult = await catRes.json();
                if (!catResult.success || !catResult.data) {
                    window.location.href = "/";
                    return;
                }

                const category = catResult.data;

                // Update page title and meta
                document.title = `${category.name} | Vapezone`;
                if (titleEl) titleEl.textContent = category.name;
                if (subtitleEl) subtitleEl.textContent = `Explora nuestra colección de ${category.name.toLowerCase()}`;

                // Populate sidebar categories
                if (allCatRes.ok && categoryListEl) {
                    const allCatResult = await allCatRes.json();
                    if (allCatResult.success && allCatResult.data) {
                        const cats = allCatResult.data
                            .filter((c: any) => c.is_active)
                            .sort((a: any, b: any) => a.display_order - b.display_order);
                        categoryListEl.innerHTML = cats.map((c: any) =>
                            `<li><a href="/category/${c.id}" class="${c.id == categoryId ? "active" : ""}">${c.name}</a></li>`
                        ).join("");
                    }
                }

                // Fetch products for this category
                const prodRes = await fetch(`${API_BASE_URL}/products?category_id=${category.id}&limit=100`);
                if (!prodRes.ok) throw new Error("products fetch failed");

                const prodResult = await prodRes.json();
                let products: any[] = [];
                if (prodResult.success && prodResult.data) {
                    products = prodResult.data
                        .filter((p: any) => p.is_active && p.featured != 1 && p.featured !== true && p.featured !== "1")
                        .sort((a: any, b: any) => a.display_order - b.display_order);
                }

                // Hide skeleton, show content
                if (skeleton) skeleton.style.display = "none";
                if (content) content.style.display = "block";

                // Render products
                if (products.length === 0) {
                    if (emptyState) emptyState.style.display = "block";
                } else if (productsGrid) {
                    productsGrid.innerHTML = products.map((product: any, index: number) => {
                        const price = product.sale_price && parseFloat(product.sale_price) < parseFloat(product.price)
                            ? product.sale_price : product.price;
                        const hasDiscount = product.sale_price && parseFloat(product.sale_price) < parseFloat(product.price);
                        return `
                        <a href="/product/${product.id}" class="product-card reveal-item" style="transition-delay: ${index * 50}ms" data-price="${price}">
                            <div class="product-image-wrapper">
                                ${hasDiscount ? '<span class="product-badge">Oferta</span>' : ""}
                                <img src="${product.image_url}" alt="${product.name}" loading="lazy" />
                            </div>
                            <div class="product-info">
                                <p class="product-brand">${product.brand || ""}</p>
                                <h3 class="product-name">${product.name}</h3>
                                <div class="product-price-row">
                                    <span class="product-price">$${price}</span>
                                    ${hasDiscount ? `<span class="product-original-price">$${product.price}</span>` : ""}
                                </div>
                            </div>
                        </a>`;
                    }).join("");

                    // Animate reveal-items after content loads
                    setTimeout(() => {
                        document.querySelectorAll('.reveal-item').forEach(el => el.classList.add('is-visible'));
                    }, 100);
                }

                // Price filter
                const minInput = document.getElementById("min-price") as HTMLInputElement;
                const maxInput = document.getElementById("max-price") as HTMLInputElement;
                const applyBtn = document.getElementById("apply-price-btn");
                const resetBtn = document.getElementById("reset-price-btn");

                function filterProducts() {
                    const min = parseFloat(minInput?.value) || 0;
                    const max = parseFloat(maxInput?.value) || Infinity;
                    document.querySelectorAll(".product-card").forEach(card => {
                        const el = card as HTMLElement;
                        const price = parseFloat(el.dataset.price || "0");
                        el.style.display = (price >= min && price <= max) ? "flex" : "none";
                    });
                }

                function resetFilters() {
                    if (minInput) minInput.value = "";
                    if (maxInput) maxInput.value = "";
                    document.querySelectorAll(".product-card").forEach(card => {
                        (card as HTMLElement).style.display = "flex";
                    });
                }

                if (applyBtn) applyBtn.addEventListener("click", filterProducts);
                if (resetBtn) resetBtn.addEventListener("click", resetFilters);

                // Search
                initSearch();

            } catch (e) {
                console.error("Error loading category page:", e);
                if (skeleton) skeleton.style.display = "none";
                if (pageError) pageError.style.display = "flex";
            }
        }

        function initSearch() {
            const searchInput = document.getElementById("product-search") as HTMLInputElement;
            const searchDropdown = document.getElementById("search-dropdown");
            let allProducts: any[] = [];
            let isFetching = false;

            if (!searchInput || !searchDropdown) return;

            searchInput.addEventListener("focus", async () => {
                if (allProducts.length === 0 && !isFetching) {
                    isFetching = true;
                    try {
                        const res = await fetch(`${API_BASE_URL}/products?limit=1000`);
                        const json = await res.json();
                        if (json.success) allProducts = json.data.filter((p: any) => p.is_active);
                    } catch (e) {
                        console.error("Search fetch error", e);
                    } finally {
                        isFetching = false;
                    }
                }
            });

            searchInput.addEventListener("input", () => {
                const term = searchInput.value.toLowerCase().trim();
                if (term.length === 0) { searchDropdown.style.display = "none"; return; }

                const matches = allProducts.filter(p =>
                    (p.name && p.name.toLowerCase().includes(term)) ||
                    (p.brand && p.brand.toLowerCase().includes(term))
                ).slice(0, 6);

                if (matches.length > 0) {
                    searchDropdown.innerHTML = matches.map(p => {
                        const price = p.sale_price && parseFloat(p.sale_price) < parseFloat(p.price) ? p.sale_price : p.price;
                        return `<a href="/product/${p.id}" class="search-result-item">
                            <img src="${p.image_url}" alt="${p.name}">
                            <div class="search-result-info">
                                <span class="sr-brand">${p.brand || ""}</span>
                                <span class="sr-name">${p.name}</span>
                                <span class="sr-price">$${price}</span>
                            </div>
                        </a>`;
                    }).join("");
                    searchDropdown.style.display = "block";
                } else {
                    searchDropdown.innerHTML = '<div class="sr-empty">No se encontraron productos</div>';
                    searchDropdown.style.display = "block";
                }
            });

            document.addEventListener("click", (e) => {
                const target = e.target as Node;
                if (!searchInput.contains(target) && !searchDropdown.contains(target)) {
                    searchDropdown.style.display = "none";
                }
            });
        }

        document.addEventListener("astro:page-load", () => {
            initCategoryPage();
        });
    </script>

<style>
    .back-bar { padding: 1.5rem 5%; max-width: 1400px; margin: 0 auto; }
    .back-btn { display: inline-flex; align-items: center; gap: 0.5rem; background: transparent; border: 1px solid rgba(255,255,255,0.15); color: rgba(255,255,255,0.7); padding: 0.55rem 1.1rem; border-radius: 6px; font-family: "Inter", sans-serif; font-size: 0.9rem; cursor: pointer; transition: all 0.25s ease; letter-spacing: 0.3px; }
    .back-btn:hover { border-color: rgba(255,255,255,0.5); color: #fff; background: rgba(255,255,255,0.05); transform: translateX(-2px); }

    .category-page { padding-top: 0; min-height: 100vh; padding-bottom: 5rem; }
    .category-hero { text-align: center; margin-bottom: 4rem; padding: 0 5%; }
    .category-title { font-size: 4rem; margin-bottom: 1rem; font-family: "Oswald", sans-serif; text-transform: uppercase; letter-spacing: 2px; }
    .category-subtitle { font-size: 1.2rem; opacity: 0.7; font-weight: 300; }

    .container { max-width: 1400px; margin: 0 auto; padding: 0 5%; }
    .shop-layout { display: flex; flex-direction: column; gap: 3rem; }

    @media (min-width: 900px) {
        .shop-layout { flex-direction: row; align-items: flex-start; }
        .shop-sidebar { width: 250px; flex-shrink: 0; position: sticky; top: 20px; }
        .shop-content { flex-grow: 1; }
    }

    .filter-group { margin-bottom: 2.5rem; background: rgba(255,255,255,0.02); padding: 1.5rem; border-radius: 8px; border: 1px solid rgba(255,255,255,0.05); }
    .filter-title { font-family: "Oswald", sans-serif; font-size: 1.2rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 1.2rem; padding-bottom: 0.5rem; border-bottom: 1px solid rgba(255,255,255,0.1); }

    .category-list { list-style: none; display: flex; flex-direction: column; gap: 0.8rem; }
    .category-list a { color: rgba(255,255,255,0.6); text-decoration: none; transition: color 0.3s ease, padding-left 0.3s ease; display: block; }
    .category-list a:hover { color: #fff; padding-left: 5px; }
    .category-list a.active { color: #fff; font-weight: bold; border-left: 2px solid #fff; padding-left: 10px; }

    .price-inputs { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1rem; }
    .price-inputs input, .search-wrapper input { width: 100%; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: #fff; padding: 0.5rem; border-radius: 4px; font-family: "Inter", sans-serif; outline: none; }
    .price-inputs input:focus, .search-wrapper input:focus { border-color: rgba(255,255,255,0.5); }

    .search-dropdown { position: absolute; top: 100%; left: 0; width: 100%; background: #111; border: 1px solid rgba(255,255,255,0.1); border-radius: 4px; margin-top: 5px; max-height: 400px; overflow-y: auto; display: none; z-index: 100; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
    .search-result-item { display: flex; align-items: center; gap: 10px; padding: 10px; text-decoration: none; color: #fff; border-bottom: 1px solid rgba(255,255,255,0.05); transition: background 0.2s; }
    .search-result-item:hover { background: rgba(255,255,255,0.05); }
    .search-result-item img { width: 40px; height: 40px; object-fit: cover; border-radius: 4px; background: #000; }
    .search-result-info { display: flex; flex-direction: column; }
    .sr-brand { font-size: 0.7rem; opacity: 0.5; text-transform: uppercase; }
    .sr-name { font-size: 0.85rem; font-weight: 600; }
    .sr-price { font-size: 0.8rem; color: #fff; font-family: "Oswald", sans-serif; }
    .sr-empty { padding: 15px; text-align: center; font-size: 0.9rem; opacity: 0.6; }

    .filter-btn { width: 100%; padding: 0.8rem; background: #fff; color: #000; border: none; border-radius: 4px; font-family: "Oswald", sans-serif; text-transform: uppercase; font-weight: 700; cursor: pointer; transition: background 0.3s, transform 0.3s; margin-bottom: 0.5rem; }
    .filter-btn:hover { background: #e0e0e0; transform: translateY(-2px); }
    .reset-btn { background: transparent; color: #fff; border: 1px solid rgba(255,255,255,0.2); }
    .reset-btn:hover { background: rgba(255,255,255,0.1); }

    .products-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
    @media (min-width: 768px) { .products-grid { grid-template-columns: repeat(4, 1fr); } }

    .product-card { display: flex; flex-direction: column; text-decoration: none; color: #fff; background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.05); border-radius: 8px; overflow: hidden; transition: transform 0.3s ease, border-color 0.3s ease; }
    .product-card:hover { transform: translateY(-4px); border-color: rgba(255,255,255,0.15); }
    .product-image-wrapper { position: relative; aspect-ratio: 1/1; overflow: hidden; background: #111; }
    .product-image-wrapper img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s ease; }
    .product-card:hover .product-image-wrapper img { transform: scale(1.05); }
    .product-badge { position: absolute; top: 10px; left: 10px; background: #fff; color: #000; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; padding: 3px 8px; border-radius: 2px; z-index: 2; font-family: "Oswald", sans-serif; }
    .product-info { padding: 1rem; display: flex; flex-direction: column; gap: 0.25rem; }
    .product-brand { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 2px; opacity: 0.5; }
    .product-name { font-size: 1rem; line-height: 1.3; font-family: "Oswald", sans-serif; text-transform: uppercase; }
    .product-price-row { display: flex; align-items: center; gap: 0.5rem; margin-top: 0.25rem; }
    .product-price { font-family: "Oswald", sans-serif; font-size: 1.2rem; font-weight: 700; }
    .product-original-price { font-size: 0.85rem; text-decoration: line-through; opacity: 0.4; }

    .empty-state { text-align: center; padding: 4rem; background: rgba(255,255,255,0.02); border-radius: 8px; opacity: 0.7; }
    .error-state, .full-error { display: flex; flex-direction: column; align-items: center; gap: 1rem; padding: 4rem; text-align: center; background: rgba(255,50,50,0.05); border: 1px solid rgba(255,50,50,0.2); border-radius: 8px; margin: 2rem 5%; }
    .error-state button, .full-error button { background: #fff; color: #000; border: none; padding: 0.75rem 2rem; font-family: "Oswald", sans-serif; text-transform: uppercase; letter-spacing: 1px; cursor: pointer; border-radius: 4px; transition: background 0.3s; }
    .error-state button:hover, .full-error button:hover { background: #e0e0e0; }

    /* Skeletons */
    @keyframes shimmer { 0% { background-position: -200% 0; } 100% { background-position: 200% 0; } }
    .skeleton-hero { height: 200px; background: linear-gradient(90deg, #1a1a1a 25%, #2a2a2a 50%, #1a1a1a 75%); background-size: 200% 100%; animation: shimmer 1.5s infinite; }
    .skeleton-sidebar { width: 250px; flex-shrink: 0; }
    .skeleton-block { height: 150px; margin-bottom: 1.5rem; background: linear-gradient(90deg, #1a1a1a 25%, #2a2a2a 50%, #1a1a1a 75%); background-size: 200% 100%; animation: shimmer 1.5s infinite; border-radius: 8px; }
    .product-card-skeleton { aspect-ratio: 3/4; background: linear-gradient(90deg, #1a1a1a 25%, #2a2a2a 50%, #1a1a1a 75%); background-size: 200% 100%; animation: shimmer 1.5s infinite; border-radius: 8px; }

    /* Reveal */
    .reveal-item { opacity: 0; transform: translateY(30px); transition: opacity 0.8s ease-out, transform 0.8s cubic-bezier(0.2, 0.8, 0.2, 1); }
    .reveal-item.is-visible { opacity: 1; transform: translateY(0); }
</style>

<style is:global>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { background-color: #000; color: #fff; font-family: "Inter", sans-serif; overflow-x: hidden; }
    h1, h2, h3 { font-family: "Oswald", sans-serif; text-transform: uppercase; }
</style>
</BaseLayout>
