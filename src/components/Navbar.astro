---
import CartDrawer from "./CartDrawer.astro";
import AgeGate from "./AgeGate.astro";

interface Props {
    solid?: boolean; // Not strictly needed anymore with the shell design, but kept for compatibility
}

const { solid = false } = Astro.props;

const API_BASE_URL = import.meta.env.PUBLIC_API_URL;
let shopCategoryUrl = "/";
let shopCategoryName = "Shop";

try {
    const res = await fetch(`${API_BASE_URL}/categories`);
    if (res.ok) {
        const result = await res.json();
        if (result.success && result.data) {
            const cat0 = result.data.find(
                (c: any) => c.display_order === 0 && c.is_active,
            );
            if (cat0) {
                shopCategoryUrl = `/category/${cat0.id}`;
                shopCategoryName = cat0.name;
            }
        }
    }
} catch (e) {
    console.error("Error fetching categories for navbar", e);
}
---

<AgeGate />

<header class="navbar">
    <!-- ZONA IZQUIERDA: LOGO -->
    <div class="nav-left">
        <a href="/" class="logo-group">
            <img src="/favicon.ico" alt="Vapezone Logo" class="logo-icon" />
        </a>
    </div>

    <!-- ZONA CENTRO: LINKS -->
    <nav class="nav-center">
        <a href={shopCategoryUrl}>{shopCategoryName}</a>
        <a href="/faq">FAQ</a>
        <a href="/terms">Términos</a>
        <a href="https://discord.gg/38QFybEmZs">Discord</a>
    </nav>

    <!-- ZONA DERECHA: ACCIONES -->
    <div class="nav-right">
        <div class="user-menu" id="user-menu">
            <a href="/login" class="nav-link" id="nav-user-btn">Sign in</a>
            <div class="user-dropdown" id="user-dropdown">
                <p id="user-name-display" class="user-name">Usuario</p>
                <a href="/profile" class="profile-link">Mi Perfil</a>
                <a href="/orders" class="profile-link">Mis Pedidos</a>
                <button id="logout-btn" class="logout-btn">Cerrar Sesión</button>
            </div>
        </div>

        <!-- CTA Register Button (Visible if NOT logged in) -->
        <a
            href="/register"
            id="nav-register-btn"
            class="cta-btn"
            style="text-decoration: none;"
        >
            Registrarse
            <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
            >
                <path d="M5 12h14M12 5l7 7-7 7"></path>
            </svg>
        </a>

        <!-- CTA Cart Button (Hidden if NOT logged in) -->
        <button id="nav-cart-btn" class="cta-btn" style="display: none;">
            Carrito <span id="cart-badge">(0)</span>
            <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
            >
                <path d="M5 12h14M12 5l7 7-7 7"></path>
            </svg>
        </button>

        <button class="hamburger" aria-label="Menu">
            <span></span>
            <span></span>
            <span></span>
        </button>
    </div>
</header>

<CartDrawer />

<script>
    document.addEventListener("DOMContentLoaded", () => {
        // Cart toggle logic
        const cartBtn = document.getElementById("nav-cart-btn");
        if (cartBtn) {
            cartBtn.addEventListener("click", () => {
                if (window.toggleCart) window.toggleCart(true);
            });
        }

        // Listen for cart updates
        const badge = document.getElementById("cart-badge");
        document.addEventListener("cart-updated", (e) => {
            if (badge) {
                badge.textContent = `(${e.detail})`;
            }
        });

        // Auth state
        const userMenu = document.getElementById("user-menu");
        const userBtn = document.getElementById("nav-user-btn");
        const userDropdown = document.getElementById("user-dropdown");
        const userNameDisplay = document.getElementById("user-name-display");
        const logoutBtn = document.getElementById("logout-btn");
        const registerBtn = document.getElementById("nav-register-btn");

        const userStr = localStorage.getItem("angel_user");
        if (userStr) {
            try {
                const user = JSON.parse(userStr);
                userMenu?.classList.add("logged-in");
                if (userNameDisplay)
                    userNameDisplay.textContent = user.first_name || user.email;
                if (userBtn) {
                    userBtn.textContent = "Mi Cuenta";
                    userBtn.removeAttribute("href");
                }

                // Switch register to cart
                if (registerBtn) registerBtn.style.display = "none";
                if (cartBtn) cartBtn.style.display = "flex";
            } catch (e) {}
        }

        userBtn?.addEventListener("click", (e) => {
            if (userMenu?.classList.contains("logged-in")) {
                e.preventDefault();
                userDropdown?.classList.toggle("show");
            }
        });

        document.addEventListener("click", (e) => {
            if (userMenu && !userMenu.contains(e.target as Node)) {
                userDropdown?.classList.remove("show");
            }
        });

        logoutBtn?.addEventListener("click", () => {
            localStorage.removeItem("angel_user");
            localStorage.removeItem("angel_token");
            window.location.reload();
        });

        // Open cart if URL has openCart=true
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.get("openCart") === "true") {
            if (window.toggleCart) window.toggleCart(true);
            window.history.replaceState(
                {},
                document.title,
                window.location.pathname,
            );
        }

        // Prevent special symbols in text inputs and textareas
        document.addEventListener("input", (e) => {
            const target = e.target as HTMLInputElement | HTMLTextAreaElement;
            if (
                target &&
                (target.tagName === "INPUT" || target.tagName === "TEXTAREA")
            ) {
                const isTextInput =
                    target.tagName === "INPUT" &&
                    (target as HTMLInputElement).type === "text";
                const isTextArea = target.tagName === "TEXTAREA";

                if (isTextInput || isTextArea) {
                    // Permits alphanumeric, spaces, and basic punctuation: # . , - @ _ ñ Ñ á é í ó ú Á É Í Ó Ú ü Ü
                    const sanitized = target.value.replace(
                        /[^a-zA-Z0-9\s#.,\-@_ñÑáéíóúÁÉÍÓÚüÜ]/g,
                        "",
                    );
                    if (target.value !== sanitized) {
                        target.value = sanitized;
                    }
                }
            }
        });
    });
</script>

<style is:global>
    /* TOKENS DE DISEÑO */
    :root {
        --color-brand-bg: #000000;
        --color-shell-bg: #0a0a0a;
        --color-text-primary: #ffffff;
        --color-text-secondary: #999999;
        --color-text-hover: #ffffff;
        --color-cta-bg: #ffffff;
        --color-cta-bg-hover: #e0e0e0;
        --color-cta-text: #000000;

        --radius-page-corner: 32px;
        --radius-button: 9999px;
        --navbar-padding-x: 48px;
        --navbar-padding-y: 24px;
        --gap-nav-links: 32px;
    }

    @media (max-width: 1024px) {
        :root {
            --radius-page-corner: 20px;
            --navbar-padding-x: 20px;
            --navbar-padding-y: 16px;
        }
    }

    /* GLOBAL SHELL TRICK */
    html {
        background-color: var(--color-brand-bg);
    }

    body {
        background-color: var(--color-shell-bg) !important;
        margin: 0;
        min-height: 100vh;
        overflow-x: hidden;
    }

    @media (max-width: 1024px) {
        body {
            min-height: 100vh;
        }
    }

    /* FIXES FOR PREVIOUS PAGES */
    .checkout-container,
    .profile-container {
        padding-top: 20px !important;
    }

    /* NAVBAR STYLES */
    .navbar {
        position: relative;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: var(--navbar-padding-y) var(--navbar-padding-x);
        background: transparent;
        font-family: "Inter", sans-serif;
    }

    /* LEFT ZONE */
    .nav-left {
        display: flex;
        align-items: center;
        width: 120px; /* Space placeholder for absolute logo */
    }

    .logo-group {
        display: flex;
        align-items: center;
        text-decoration: none;
        color: var(--color-text-primary);
    }

    .logo-icon {
        width: 110px;
        height: 110px;
        object-fit: contain;
        position: absolute;
        top: 50%;
        left: var(--navbar-padding-x);
        transform: translateY(-50%);
        z-index: 10;
    }

    /* CENTER ZONE */
    .nav-center {
        display: flex;
        align-items: center;
        gap: var(--gap-nav-links);
    }

    .nav-center a,
    .nav-dropdown span {
        color: var(--color-text-secondary);
        text-decoration: none;
        font-weight: 400;
        font-size: 0.95rem;
        transition: color 0.3s ease;
        cursor: pointer;
    }

    .nav-center a:hover,
    .nav-dropdown:hover span {
        color: var(--color-text-hover);
    }

    .nav-dropdown {
        position: relative;
    }

    .dropdown-content {
        position: absolute;
        top: 100%;
        left: 50%;
        transform: translateX(-50%) translateY(10px);
        background: #111;
        padding: 0.8rem 1.2rem;
        border-radius: 12px;
        border: 1px solid rgba(255, 255, 255, 0.1);
        opacity: 0;
        visibility: hidden;
        transition: all 0.3s ease;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .nav-dropdown:hover .dropdown-content {
        opacity: 1;
        visibility: visible;
        transform: translateX(-50%) translateY(5px);
    }

    /* RIGHT ZONE */
    .nav-right {
        display: flex;
        align-items: center;
        gap: 24px;
    }

    .nav-link {
        color: var(--color-text-secondary);
        text-decoration: none;
        font-weight: 400;
        font-size: 0.95rem;
        transition: color 0.3s ease;
        cursor: pointer;
    }

    .nav-link:hover {
        color: var(--color-text-hover);
    }

    .cta-btn {
        background-color: var(--color-cta-bg);
        color: var(--color-cta-text);
        border: none;
        border-radius: var(--radius-button);
        padding: 12px 20px;
        font-family: "Inter", sans-serif;
        font-weight: 600;
        font-size: 0.95rem;
        display: flex;
        align-items: center;
        gap: 8px;
        cursor: pointer;
        transition: background-color 0.3s ease;
    }

    .cta-btn:hover {
        background-color: var(--color-cta-bg-hover);
    }

    /* USER DROPDOWN */
    .user-menu {
        position: relative;
    }

    .user-dropdown {
        position: absolute;
        top: 100%;
        right: 0;
        margin-top: 10px;
        background: #111;
        border: 1px solid rgba(255, 255, 255, 0.1);
        padding: 1rem;
        border-radius: 12px;
        min-width: 150px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
        opacity: 0;
        visibility: hidden;
        transform: translateY(10px);
        transition: all 0.3s ease;
        z-index: 100;
    }

    .user-dropdown.show {
        opacity: 1;
        visibility: visible;
        transform: translateY(0);
    }

    .user-name {
        font-weight: 600;
        font-size: 0.9rem;
        margin-bottom: 0.5rem;
        padding-bottom: 0.5rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
        white-space: nowrap;
    }

    .profile-link,
    .logout-btn {
        display: block;
        color: var(--color-text-secondary);
        text-decoration: none;
        font-size: 0.9rem;
        padding: 0.5rem 0;
        border: none;
        background: transparent;
        text-align: left;
        cursor: pointer;
        transition: color 0.3s ease;
        width: 100%;
    }

    .profile-link:hover {
        color: var(--color-text-hover);
    }

    .logout-btn:hover {
        color: #f44336;
    }

    /* RESPONSIVE */
    .hamburger {
        display: none;
        flex-direction: column;
        justify-content: space-between;
        width: 24px;
        height: 16px;
        background: transparent;
        border: none;
        cursor: pointer;
    }

    .hamburger span {
        width: 100%;
        height: 2px;
        background-color: var(--color-text-primary);
    }

    @media (max-width: 1024px) {
        .nav-center {
            display: none;
        }

        .hamburger {
            display: flex;
        }

        .nav-right .nav-link {
            display: none; /* Hide sign in text on mobile */
        }

        .cta-btn {
            padding: 8px 16px;
            font-size: 0.85rem;
        }
    }
</style>
