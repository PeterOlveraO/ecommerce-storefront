---
interface Props {
  product: any;
  index?: number;
}

const { product, index = 0 } = Astro.props;
---
<a
    href={`/product/${product.id}`}
    class="product-card reveal-item"
    style={`transition-delay: ${index * 0.05 + 0.1}s`}
    data-price={product.sale_price && parseFloat(product.sale_price) < parseFloat(product.price) ? product.sale_price : product.price}
    data-category={product.category_id}
>
    <div class="product-image-container">
        <img
            src={product.image_url}
            alt={product.name}
            loading="lazy"
        />
        {product.sale_price && parseFloat(product.sale_price) < parseFloat(product.price) && (
            <span class="sale-badge">Sale</span>
        )}
    </div>
    <div class="product-info">
        <p class="product-brand">{product.brand}</p>
        <h3 class="product-grid-name">{product.name}</h3>
        <div class="price-container">
            {product.sale_price && parseFloat(product.sale_price) < parseFloat(product.price) ? (
                <>
                    <span class="current-price">${product.sale_price}</span>
                    <span class="original-price">${product.price}</span>
                </>
            ) : (
                <span class="current-price">${product.price}</span>
            )}
        </div>
    </div>
</a>

<style>
    .product-card {
        display: flex;
        flex-direction: column;
        text-decoration: none;
        color: #fff;
        transition: transform 0.3s ease;
    }
    .product-card:hover {
        transform: translateY(-5px);
    }
    .product-image-container {
        position: relative;
        width: 100%;
        aspect-ratio: 4/5;
        overflow: hidden;
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.03);
        margin-bottom: 1rem;
    }
    .product-image-container img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }
    .product-card:hover .product-image-container img {
        transform: scale(1.05);
    }
    .sale-badge {
        position: absolute;
        top: 10px;
        right: 10px;
        background: #fff;
        color: #000;
        padding: 4px 8px;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        border-radius: 2px;
        font-family: "Oswald", sans-serif;
    }
    .product-brand {
        font-size: 0.8rem;
        opacity: 0.6;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 0.2rem;
    }
    .product-grid-name {
        font-size: 1.1rem;
        font-weight: 400;
        margin-bottom: 0.5rem;
        font-family: "Inter", sans-serif;
        text-transform: none;
        line-height: 1.4;
    }
    .price-container {
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }
    .current-price {
        font-family: "Oswald", sans-serif;
        font-size: 1.2rem;
        font-weight: 700;
    }
    .original-price {
        font-size: 0.9rem;
        text-decoration: line-through;
        opacity: 0.5;
    }
    .reveal-item {
        opacity: 0;
        transform: translateY(40px);
        transition: opacity 0.8s ease-out, transform 0.8s cubic-bezier(0.2, 0.8, 0.2, 1);
    }
    :global(.is-visible) .reveal-item,
    .reveal-item:global(.is-visible) {
        opacity: 1;
        transform: translateY(0);
    }
</style>
