---
// CartDrawer.astro
---
<div id="cart-overlay" class="cart-overlay"></div>
<div id="cart-drawer" class="cart-drawer">
    <div class="cart-header">
        <h2>TU CARRITO</h2>
        <button id="close-cart-btn" class="close-btn" aria-label="Cerrar carrito">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M18 6L6 18M6 6l12 12"></path>
            </svg>
        </button>
    </div>
    
    <div class="cart-items" id="cart-items">
        <!-- JS will populate this -->
    </div>
    
    <div class="cart-footer">
        <div class="cart-summary">
            <span>Subtotal</span>
            <span id="cart-subtotal">$0.00</span>
        </div>
        <p class="shipping-note">Costo de envío se calculará en el siguiente paso.</p>
        <button id="checkout-btn" class="checkout-btn">FINALIZAR COMPRA</button>
        <div id="checkout-message" class="checkout-message"></div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const cartDrawer = document.getElementById("cart-drawer");
        const cartOverlay = document.getElementById("cart-overlay");
        const closeBtn = document.getElementById("close-cart-btn");
        const cartItemsContainer = document.getElementById("cart-items");
        const cartSubtotalEl = document.getElementById("cart-subtotal");
        const checkoutBtn = document.getElementById("checkout-btn");
        const checkoutMsg = document.getElementById("checkout-message");
        
        let cart = JSON.parse(localStorage.getItem('angel_cart') || '[]');
        
        // Expose toggle globally so Navbar or Add to Cart buttons can open it
        window.toggleCart = (forceOpen = false) => {
            const isOpen = cartDrawer?.classList.contains('open');
            if (isOpen && !forceOpen) {
                cartDrawer?.classList.remove('open');
                cartOverlay?.classList.remove('open');
                document.body.style.overflow = '';
            } else {
                cartDrawer?.classList.add('open');
                cartOverlay?.classList.add('open');
                document.body.style.overflow = 'hidden';
                renderCart();
            }
        };

        window.addToCart = (product) => {
            const existingItem = cart.find(item => item.id === product.id);
            if (existingItem) {
                existingItem.quantity += 1;
            } else {
                cart.push({ ...product, quantity: 1 });
            }
            saveCart();
            window.toggleCart(true);
            updateCartBadge();
        };

        function updateCartBadge() {
            const count = cart.reduce((sum, item) => sum + item.quantity, 0);
            document.dispatchEvent(new CustomEvent('cart-updated', { detail: count }));
        }

        function saveCart() {
            localStorage.setItem('angel_cart', JSON.stringify(cart));
            updateCartBadge();
        }

        function removeFromCart(id) {
            cart = cart.filter(item => item.id !== id);
            saveCart();
            renderCart();
        }

        function changeQuantity(id, delta) {
            const item = cart.find(item => item.id === id);
            if (item) {
                item.quantity += delta;
                if (item.quantity <= 0) {
                    removeFromCart(id);
                } else {
                    saveCart();
                    renderCart();
                }
            }
        }

        function renderCart() {
            if (!cartItemsContainer) return;
            
            if (cart.length === 0) {
                cartItemsContainer.innerHTML = '<div class="empty-cart"><p>Tu carrito está vacío.</p></div>';
                cartSubtotalEl!.textContent = '$0.00';
                return;
            }

            let html = '';
            let subtotal = 0;

            cart.forEach(item => {
                const price = parseFloat(item.price);
                subtotal += price * item.quantity;

                html += `
                    <div class="cart-item">
                        <img src="${item.image_url}" alt="${item.name}" class="cart-item-img" />
                        <div class="cart-item-info">
                            <p class="cart-item-brand">${item.brand}</p>
                            <h4 class="cart-item-name">${item.name}</h4>
                            <p class="cart-item-price">$${price.toFixed(2)}</p>
                            <div class="cart-item-controls">
                                <div class="quantity-ctrl">
                                    <button class="qty-btn minus" data-id="${item.id}">-</button>
                                    <span>${item.quantity}</span>
                                    <button class="qty-btn plus" data-id="${item.id}">+</button>
                                </div>
                                <button class="remove-btn" data-id="${item.id}">Eliminar</button>
                            </div>
                        </div>
                    </div>
                `;
            });

            cartItemsContainer.innerHTML = html;
            cartSubtotalEl!.textContent = `$${subtotal.toFixed(2)}`;

            // Attach event listeners for dynamic buttons
            document.querySelectorAll('.qty-btn').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    const id = (e.target as HTMLButtonElement).dataset.id;
                    const isPlus = (e.target as HTMLButtonElement).classList.contains('plus');
                    if(id) changeQuantity(id, isPlus ? 1 : -1);
                });
            });

            document.querySelectorAll('.remove-btn').forEach(btn => {
                btn.addEventListener('click', (e) => {
                    const id = (e.target as HTMLButtonElement).dataset.id;
                    if(id) removeFromCart(id);
                });
            });
        }

        async function handleCheckout() {
            if (cart.length === 0) return;
            
            if(checkoutMsg) {
                checkoutMsg.textContent = 'Procesando orden...';
                checkoutMsg.style.color = 'white';
            }
            if(checkoutBtn) (checkoutBtn as HTMLButtonElement).disabled = true;

            const API_BASE_URL = "http://localhost:3000"; // Assuming local backend
            const payload = {
                payment_method_id: "00000000-0000-0000-0000-000000000000", // Default dummy UUID
                items: cart.map(item => ({
                    product_id: item.id,
                    quantity: item.quantity
                })),
                shipping_cost: 150.00,
                notes: "Orden desde Frontend Ecommerce Angel"
            };

            try {
                const res = await fetch(`${API_BASE_URL}/orders`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(payload)
                });
                
                const result = await res.json();
                
                if (res.ok && result.success) {
                    if(checkoutMsg) {
                        checkoutMsg.textContent = `¡Orden Creada! ID: ${result.data?.id || 'Exitosa'}`;
                        checkoutMsg.style.color = '#4caf50';
                    }
                    cart = [];
                    saveCart();
                    renderCart();
                    setTimeout(() => window.toggleCart(false), 3000);
                } else {
                    throw new Error(result.message || 'Error al procesar orden');
                }
            } catch (err) {
                console.error("Checkout Error:", err);
                if(checkoutMsg) {
                    checkoutMsg.textContent = err.message || 'Hubo un error al crear la orden. Intente de nuevo.';
                    checkoutMsg.style.color = '#f44336';
                }
            } finally {
                if(checkoutBtn) (checkoutBtn as HTMLButtonElement).disabled = false;
            }
        }

        // Init listeners
        closeBtn?.addEventListener('click', () => window.toggleCart(false));
        cartOverlay?.addEventListener('click', () => window.toggleCart(false));
        checkoutBtn?.addEventListener('click', handleCheckout);
        
        // Initial badge sync
        updateCartBadge();
    });

    // TypeScript globally defined functions hack
    declare global {
        interface Window {
            toggleCart: (forceOpen?: boolean) => void;
            addToCart: (product: any) => void;
        }
    }
</script>

<style>
    .cart-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100vw;
        height: 100vh;
        background: rgba(0, 0, 0, 0.7);
        backdrop-filter: blur(5px);
        z-index: 1000;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.3s ease;
    }
    .cart-overlay.open {
        opacity: 1;
        pointer-events: all;
    }

    .cart-drawer {
        position: fixed;
        top: 0;
        right: -100%;
        width: 100%;
        max-width: 450px;
        height: 100vh;
        background: #111;
        z-index: 1001;
        display: flex;
        flex-direction: column;
        transition: right 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
        border-left: 1px solid rgba(255,255,255,0.1);
        box-shadow: -5px 0 30px rgba(0,0,0,0.5);
    }
    .cart-drawer.open {
        right: 0;
    }

    .cart-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 2rem;
        border-bottom: 1px solid rgba(255,255,255,0.1);
    }
    .cart-header h2 {
        font-family: "Oswald", sans-serif;
        font-size: 1.5rem;
        margin: 0;
    }
    .close-btn {
        background: transparent;
        border: none;
        color: #fff;
        cursor: pointer;
        opacity: 0.7;
        transition: opacity 0.3s, transform 0.3s;
    }
    .close-btn:hover {
        opacity: 1;
        transform: rotate(90deg);
    }

    .cart-items {
        flex: 1;
        overflow-y: auto;
        padding: 2rem;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .empty-cart {
        text-align: center;
        opacity: 0.5;
        margin-top: 2rem;
    }

    .cart-item {
        display: flex;
        gap: 1rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid rgba(255,255,255,0.05);
    }
    .cart-item-img {
        width: 80px;
        height: 100px;
        object-fit: cover;
        border-radius: 4px;
        background: #222;
    }
    .cart-item-info {
        flex: 1;
        display: flex;
        flex-direction: column;
    }
    .cart-item-brand {
        font-size: 0.75rem;
        opacity: 0.6;
        text-transform: uppercase;
        font-family: "Oswald", sans-serif;
    }
    .cart-item-name {
        font-size: 1rem;
        margin: 0.2rem 0;
        font-weight: 400;
    }
    .cart-item-price {
        font-family: "Oswald", sans-serif;
        font-weight: 700;
        margin-bottom: 0.5rem;
    }
    .cart-item-controls {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: auto;
    }
    .quantity-ctrl {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        background: rgba(255,255,255,0.05);
        border-radius: 4px;
        padding: 0.2rem;
    }
    .qty-btn {
        background: transparent;
        border: none;
        color: #fff;
        width: 24px;
        height: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        opacity: 0.7;
    }
    .qty-btn:hover { opacity: 1; }
    .remove-btn {
        background: transparent;
        border: none;
        color: #f44336;
        font-size: 0.8rem;
        cursor: pointer;
        opacity: 0.8;
        text-decoration: underline;
    }
    .remove-btn:hover { opacity: 1; }

    .cart-footer {
        padding: 2rem;
        background: rgba(255,255,255,0.02);
        border-top: 1px solid rgba(255,255,255,0.1);
    }
    .cart-summary {
        display: flex;
        justify-content: space-between;
        font-size: 1.2rem;
        font-family: "Oswald", sans-serif;
        font-weight: 700;
        margin-bottom: 0.5rem;
    }
    .shipping-note {
        font-size: 0.8rem;
        opacity: 0.6;
        margin-bottom: 1.5rem;
    }
    .checkout-btn {
        width: 100%;
        padding: 1rem;
        background: #fff;
        color: #000;
        border: none;
        font-family: "Oswald", sans-serif;
        font-size: 1.1rem;
        font-weight: 700;
        cursor: pointer;
        transition: background 0.3s, transform 0.3s;
        border-radius: 4px;
    }
    .checkout-btn:hover {
        background: #f0f0f0;
        transform: translateY(-2px);
    }
    .checkout-btn:disabled {
        opacity: 0.5;
        cursor: not-allowed;
        transform: none;
    }
    .checkout-message {
        margin-top: 1rem;
        font-size: 0.9rem;
        text-align: center;
    }
</style>
